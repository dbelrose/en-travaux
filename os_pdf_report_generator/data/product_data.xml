<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Catégorie de produit dédiée -->
    <record id="product_category_pdf_credits" model="product.category">
        <field name="name">Crédits d'impression PDF</field>
    </record>

    <!-- Produit "Crédit d'impression PDF" -->
    <record id="product_template_pdf_print_credit" model="product.template">
        <field name="name">Crédit d'impression PDF</field>
        <field name="type">service</field>
        <field name="categ_id" ref="product_category_pdf_credits"/>
        <field name="sale_ok">True</field>
        <field name="purchase_ok">False</field>
        <field name="description_sale">
            Recharge de crédits d'impression PDF pour votre société.
            Chaque crédit permet de générer un document PDF depuis un modèle de données Odoo.
        </field>
        <field name="list_price">1.0</field>
        <field name="uom_id" ref="uom.product_uom_unit"/>
        <field name="uom_po_id" ref="uom.product_uom_unit"/>
        <field name="base_unit_count">0</field>
    </record>
</odoo>
