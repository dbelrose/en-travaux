<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Vue formulaire du wizard -->
    <record id="view_pdf_print_credit_wizard_form" model="ir.ui.view">
        <field name="name">pdf.print.credit.wizard.form</field>
        <field name="model">pdf.print.credit.wizard</field>
        <field name="arch" type="xml">
            <form string="Réapprovisionner les crédits d'impression PDF">
                <sheet>
                    <div class="oe_title">
                        <h1>Réapprovisionner les crédits d'impression PDF</h1>
                    </div>

                    <group>
                        <group string="Société">
                            <field name="company_id" options="{'no_quick_create': True}"/>
                            <field name="current_credits" readonly="1"
                                   string="Crédits actuels"/>
                        </group>
                        <group string="Réapprovisionnement">
                            <field name="qty" string="Quantité à ajouter"/>
                            <field name="product_id" readonly="1" optional="show"/>
                        </group>
                    </group>

                    <!-- Section bon de commande -->
                    <group string="Bon de commande (optionnel)">
                        <field name="create_sale_order" string="Créer un bon de commande"/>
                        <field name="partner_id"
                               invisible="not create_sale_order"
                               options="{'no_quick_create': True}"/>
                        <field name="note"
                               invisible="not create_sale_order"
                               placeholder="Note interne pour le bon de commande..."/>
                    </group>

                    <div class="alert alert-warning" role="alert">
                        <strong>ℹ️ Information :</strong>
                        Le bouton <strong>"Ajouter les crédits"</strong> incrémente
                        immédiatement le stock sans créer de document commercial.<br/>
                        Si vous souhaitez conserver une trace commerciale, cochez
                        <em>"Créer un bon de commande"</em> puis utilisez le bouton
                        <strong>"Créer le bon de commande"</strong> — les crédits
                        ne seront PAS ajoutés automatiquement, vous devrez les ajouter
                        manuellement après confirmation du paiement.
                    </div>
                </sheet>
                <footer>
                    <button string="Ajouter les crédits"
                            name="action_add_credits"
                            type="object"
                            class="btn-primary"/>
                    <button string="Créer le bon de commande"
                            name="action_create_sale_order"
                            type="object"
                            class="btn-secondary"
                            invisible="not create_sale_order"/>
                    <button string="Annuler"
                            class="btn-secondary"
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- Action window pour ouvrir le wizard -->
    <record id="action_pdf_print_credit_wizard" model="ir.actions.act_window">
        <field name="name">Réapprovisionner les crédits d'impression</field>
        <field name="res_model">pdf.print.credit.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="context">{'default_company_id': company_id}</field>
    </record>

    <!-- Entrée de menu dans PDF Report -->
    <menuitem
        name="Réapprovisionner les crédits"
        id="menu_pdf_credit_wizard"
        parent="menu_main_pdf_report"
        action="action_pdf_print_credit_wizard"
        sequence="10"/>
</odoo>
