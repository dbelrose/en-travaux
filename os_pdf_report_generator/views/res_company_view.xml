<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Ajout de l'onglet "Crédits PDF" dans la fiche société -->
    <record id="view_company_form_pdf_credits" model="ir.ui.view">
        <field name="name">res.company.form.pdf.credits</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//page[last()]" position="after">
                <page string="Crédits d'impression PDF" name="pdf_print_credits">
                    <group>
                        <group string="Stock de crédits">
                            <field name="pdf_print_credits"
                                   widget="integer"
                                   string="Crédits disponibles"/>
                        </group>
                        <group string="Actions">
                            <div class="o_field_widget">
                                <button name="%(action_pdf_print_credit_wizard)d"
                                        type="action"
                                        string="Réapprovisionner les crédits"
                                        class="btn btn-primary"
                                        context="{'default_company_id': active_id}"/>
                            </div>
                        </group>
                    </group>
                    <div class="alert alert-info" role="alert"
                         invisible="pdf_print_credits &gt; 20">
                        <strong>⚠️ Attention :</strong>
                        Il ne reste que <field name="pdf_print_credits" readonly="1" nolabel="1"/>
                        crédit(s) d'impression PDF. Pensez à réapprovisionner votre stock.
                    </div>
                    <div class="alert alert-danger" role="alert"
                         invisible="pdf_print_credits &gt; 0">
                        <strong>⛔ Stock épuisé :</strong>
                        Votre société n'a plus de crédits d'impression PDF.
                        Les impressions sont bloquées jusqu'au réapprovisionnement.
                    </div>
                </page>
            </xpath>
        </field>
    </record>
</odoo>
