<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- Vue calendrier pour booking.import.line -->
        <record id="view_booking_import_line_calendar" model="ir.ui.view">
            <field name="name">booking.import.line.calendar</field>
            <field name="model">booking.import.line</field>
            <field name="arch" type="xml">
                <calendar string="Calendrier Réservations"
                          date_start="arrival_date"
                          date_stop="departure_date"
                          mode="month"
                          color="property_type_id"
                          event_open_popup="true"
                          quick_create="false">

                    <!-- Titre de l'événement -->
                    <field name="booking_reference"/>
                    <field name="partner_id"/>
                    <field name="property_type_id"/>
                    <field name="pax_nb"/>
                    <field name="rate"/>
                    <field name="origin"/>

                </calendar>
            </field>
        </record>

        <!-- Extension de l'action existante pour ajouter la vue calendrier -->
        <record id="os_hospitality_managment.action_booking_import_line" model="ir.actions.act_window">
            <field name="view_mode">tree,form,calendar</field>
        </record>

        <!-- Vue calendrier alternative avec plus de détails -->
        <record id="view_booking_import_line_calendar_detailed" model="ir.ui.view">
            <field name="name">booking.import.line.calendar.detailed</field>
            <field name="model">booking.import.line</field>
            <field name="priority">20</field>
            <field name="arch" type="xml">
                <calendar string="Calendrier Réservations"
                          date_start="arrival_date"
                          date_stop="departure_date"
                          mode="month"
                          color="property_type_id"
                          event_open_popup="true"
                          quick_create="false"
                          date_delay="duration_nights">

                    <!-- Affichage enrichi -->
                    <field name="booking_reference"/>
                    <field name="partner_id" avatar_field="image_128"/>
                    <field name="property_type_id"
                           options="{'color_field': 'color'}"/>
                    <field name="pax_nb"/>
                    <field name="duration_nights"/>
                    <field name="rate"/>
                    <field name="origin"/>
                    <field name="status"/>
                    <field name="company_id" groups="base.group_multi_company"/>

                </calendar>
            </field>
        </record>

        <!-- Action spécifique pour calendrier Airbnb -->
        <record id="action_booking_airbnb_calendar" model="ir.actions.act_window">
            <field name="name">Calendrier Airbnb</field>
            <field name="res_model">booking.import.line</field>
            <field name="view_mode">calendar,tree,form</field>
            <field name="domain">[('origin', '=', 'airbnb')]</field>
            <field name="context">{
                'search_default_origin_airbnb': 1,
                'calendar_mode': 'month'
            }</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Aucune réservation Airbnb
                </p>
                <p>
                    Le calendrier affiche toutes les réservations avec une couleur par logement.
                </p>
            </field>
        </record>

        <!-- Menu pour le calendrier Airbnb -->
        <menuitem id="menu_booking_airbnb_calendar"
                  name="📅 Calendrier"
                  parent="os_airbnb_email_import.menu_airbnb_email_root"
                  action="action_booking_airbnb_calendar"
                  sequence="5"/>

    </data>
</odoo>