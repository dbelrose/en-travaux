<?xml version="1.0"?>
<odoo noupdate="1">

    <record id="ir_mail_server_pf_gov_trav" model="ir.mail_server">
        <field name="active" eval="True"/>
        <!--
            force_alias_domain supprimé en v17 de ir.mail_server.
            Le domaine d'alias se configure désormais via :
            Paramètres > Domaines d'alias (mail.alias.domain)
            puis en l'associant à la compagnie concernée.
        -->
        <field name="name">Direction du travail</field>
        <field name="sequence" eval="10"/>
        <field name="smtp_host">smtp.gov.pf</field>
        <field name="smtp_port" eval="25"/>
    </record>

</odoo>