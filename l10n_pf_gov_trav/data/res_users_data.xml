<?xml version="1.0"?>
<odoo noupdate="1">

    <record id="res_users_pf_gov_trav_user" model="res.users">
        <field name="server_mail_id" ref="ir_mail_server_pf_gov_trav"/>
        <field name="name">Utilisateur PF-GOV-TRAV</field>
        <field name="login">user@travail.gov.pf</field>
        <field name="lang">fr_FR</field>
        <field name="tz">Pacific/Tahiti</field>
        <field name="company_id" ref="res_company_pf_trav"/>
        <!--
            v18 : (6, 0, [...]) toujours valide mais la syntaxe
            recommandée est désormais [(set, ref(...))]
            On conserve l'ancienne syntaxe, elle fonctionne encore.
        -->
        <field name="company_ids" eval="[(6, 0, [ref('res_company_pf_trav')])]"/>
        <!--
            'employee' (boolean) supprimé de res.users en v16.
            En v18, le lien employé se fait via hr.employee.
            Ce module ne dépendant pas de 'hr', ce champ est supprimé.
        -->
        <field name="groups_id" eval="[(4, ref('res_groups_pf_gov_trav_user'))]"/>
        <field name="active" eval="False"/>
    </record>

    <record id="res_users_pf_gov_trav_manager" model="res.users">
        <field name="name">Administrateur PF-GOV-TRAV</field>
        <field name="login">manager@travail.gov.pf</field>
        <field name="lang">fr_FR</field>
        <field name="tz">Pacific/Tahiti</field>
        <field name="company_id" ref="res_company_pf_trav"/>
        <field name="company_ids" eval="[(6, 0, [ref('res_company_pf_trav')])]"/>
        <field name="groups_id" eval="[(4, ref('res_groups_pf_gov_trav_manager'))]"/>
        <field name="active" eval="False"/>
    </record>

</odoo>