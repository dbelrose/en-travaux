<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Aucun enregistrement par défaut : partner_id et account_id
        sont propres à chaque installation et ne peuvent pas être
        pré-renseignés ici.

        Créez vos règles depuis :
        Comptabilité > Configuration > Règles import email fournisseurs

        Régex EDT à copier/coller :
          regex_invoice_number : facture\s+(\S+)\s+du
          regex_invoice_date   : du\s+(\d{2}/\d{2}/\d{4})
          regex_amount         : montant de ([\d\s\u00a0\u202f,\.]+?)\s*(?:FCFP|XPF)
          regex_contract       : contrat\s+([\w\-]+)
    -->
</odoo>
