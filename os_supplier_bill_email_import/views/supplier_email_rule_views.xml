<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════
         Règles de parsing email fournisseur — Vue formulaire
    ════════════════════════════════════════════════════════════════════════ -->

    <record id="view_supplier_email_rule_form" model="ir.ui.view">
        <field name="name">supplier.email.rule.form</field>
        <field name="model">supplier.email.rule</field>
        <field name="arch" type="xml">
            <form string="Règle de parsing email fournisseur">
                <sheet>
                    <widget name="web_ribbon" title="Archivé"
                            bg_color="text-bg-danger"
                            invisible="active"/>

                    <!-- Smart button : factures créées -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_bills"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file-text-o"
                                invisible="bill_count == 0">
                            <field name="bill_count"
                                   string="Factures"
                                   widget="statinfo"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"
                                   placeholder="Ex : EDT Électricité"/>
                        </h1>
                    </div>

                    <!-- Indicateur de dernier import -->
                    <div class="alert alert-info" role="alert"
                         invisible="not last_import_date">
                        <strong>Dernier import :</strong>
                        <field name="last_import_result" readonly="1"/>
                        (<field name="last_import_date" widget="datetime" readonly="1"/>)
                    </div>

                    <notebook>

                        <!-- ══════════════════════════════════════════════
                             Onglet 1 — Général
                        ═══════════════════════════════════════════════════ -->
                        <page string="Général" name="general">

                            <!-- Alias email -->
                            <group string="📬 Adresse email de réception automatique">
                                <div class="alert alert-info" role="alert">
                                    <p>
                                        <strong>Configurez une règle de transfert</strong>
                                        dans votre client mail (Gmail, Outlook…) pour
                                        rediriger automatiquement les emails de ce
                                        fournisseur vers l'adresse ci-dessous.
                                    </p>
                                    <p>
                                        Odoo traitera chaque email reçu, extraira les
                                        données et créera la facture fournisseur
                                        <strong>sans intervention manuelle</strong>.
                                    </p>
                                </div>
                                <field name="alias_id"
                                       widget="mail_alias_setting"
                                       string="Alias email"/>
                            </group>

                            <group>
                                <group string="Identification de l'email (sécurité)">
                                    <field name="active" invisible="1"/>
                                    <field name="sequence"/>
                                    <field name="sender_email_pattern"
                                           placeholder="efacture@.*edt\.engie\.pf"/>
                                    <field name="subject_pattern"
                                           placeholder="facture (optionnel)"/>
                                </group>
                                <group string="Comptabilité">
                                    <field name="partner_id"/>
                                    <field name="journal_id"/>
                                    <field name="account_id"/>
                                    <field name="currency_code"/>
                                    <field name="analytic_plan_id"/>
                                </group>
                            </group>

                            <!-- Lien produit / logement -->
                            <group string="Lien produit / logement">
                                <field name="product_attribute_name"
                                       placeholder="N° de contrat EDT"/>
                            </group>

                        </page>

                        <!-- ══════════════════════════════════════════════
                             Onglet 2 — Expressions régulières
                        ═══════════════════════════════════════════════════ -->
                        <page string="Expressions régulières" name="regex">

                            <group string="Extraction des données — Corps de l'email ou PDF">
                                <div class="alert alert-secondary" role="alert">
                                    Chaque champ contient une regex Python avec
                                    <strong>un groupe capturant ( … )</strong>
                                    qui extrait la valeur souhaitée du texte source
                                    (corps de l'email ou texte du PDF selon la configuration).
                                    <br/>
                                    Exemple EDT :
                                    <em>« facture F202602042089 du 10/02/2026
                                    d'un montant de 3 354 FCFP pour le
                                    contrat 01-2022-000194 »</em>
                                </div>
                                <group>
                                    <field name="regex_invoice_number"
                                           placeholder="facture\s+(\S+)\s+du"/>
                                    <field name="regex_invoice_date"
                                           placeholder="du\s+(\d{2}/\d{2}/\d{4})"/>
                                    <field name="regex_amount"
                                           placeholder="montant de ([\d\s\u00a0\u202f,\.]+?)\s*(?:FCFP|XPF)"/>
                                    <field name="regex_contract"
                                           placeholder="contrat\s+([\w\-]+)"/>
                                </group>
                            </group>

                        </page>

                        <!-- ══════════════════════════════════════════════
                             Onglet 3 — Pièce jointe PDF
                        ═══════════════════════════════════════════════════ -->
                        <page string="Pièce jointe PDF" name="pdf">

                            <group string="Exploitation du PDF">
                                <div class="alert alert-info" role="alert">
                                    <strong>Quand activer ?</strong>
                                    Certains fournisseurs envoient l'essentiel des
                                    informations dans un PDF joint plutôt que dans
                                    le corps de l'email. Activez cette section si le
                                    corps de l'email est trop pauvre pour le parsing.
                                    <br/><br/>
                                    <strong>Moteur PDF :</strong>
                                    <em>pdfminer.six</em> (précision maximale),
                                    <em>pypdf</em> ou <em>PyPDF2</em> en fallback.
                                    Installez <code>pdfminer.six</code> si ce n'est
                                    pas encore fait :
                                    <code>pip install pdfminer.six</code>
                                </div>
                                <group>
                                    <field name="use_pdf_attachment"/>
                                    <field name="pdf_prefer_over_body"
                                           invisible="not use_pdf_attachment"/>
                                </group>
                            </group>

                            <!-- Lignes de détail -->
                            <group string="Lignes de détail du PDF"
                                   invisible="not use_pdf_attachment">
                                <div class="alert alert-secondary" role="alert">
                                    Si activé, la regex de ligne est appliquée sur
                                    le texte du PDF pour créer
                                    <strong>une ligne de facture par correspondance</strong>.
                                    <br/>
                                    La regex doit avoir <strong>2 groupes capturants</strong> :
                                    groupe 1 = libellé, groupe 2 = montant.
                                    <br/>
                                    Exemple :
                                    <code>^(.+?)\s{{2,}}([\d\s,\.]+)\s*(?:FCFP|XPF)\s*$</code>
                                    <br/>
                                    Si aucune ligne n'est trouvée, une ligne unique
                                    avec le montant total est créée en fallback.
                                </div>
                                <group>
                                    <field name="pdf_extract_lines"/>
                                    <field name="regex_pdf_line"
                                           invisible="not pdf_extract_lines"
                                           placeholder="^(.+?)\s{2,}([\d\s,\.]+)\s*(?:FCFP|XPF)\s*$"/>
                                    <field name="pdf_line_account_id"
                                           invisible="not pdf_extract_lines"/>
                                    <field name="pdf_line_tax_ids"
                                           widget="many2many_tags"
                                           invisible="not pdf_extract_lines"/>
                                </group>
                            </group>

                        </page>

                        <!-- ══════════════════════════════════════════════
                             Onglet 4 — Paiement automatique
                        ═══════════════════════════════════════════════════ -->
                        <page string="Paiement automatique" name="payment">

                            <group string="Validation et paiement automatiques">
                                <div class="alert alert-warning" role="alert">
                                    <strong>⚠ À utiliser avec précaution.</strong>
                                    La validation et le paiement automatiques
                                    conviennent aux fournisseurs de confiance dont
                                    les montants sont fixes ou vérifiés
                                    (abonnements, loyers, contrats cadre).
                                    <br/>
                                    Pour les fournisseurs à montant variable,
                                    préférez laisser la facture en brouillon
                                    pour validation manuelle avant paiement.
                                </div>
                                <group>
                                    <field name="auto_post_bill"/>
                                    <field name="auto_register_payment"
                                           invisible="not auto_post_bill"/>
                                </group>
                            </group>

                            <group string="Paramètres du paiement"
                                   invisible="not auto_register_payment">
                                <div class="alert alert-info" role="alert">
                                    Le paiement est créé en devise de la facture,
                                    pour le montant résiduel (TTC). Il est
                                    automatiquement rapproché de la facture.
                                </div>
                                <group>
                                    <field name="payment_journal_id"/>
                                    <field name="payment_date_source"/>
                                    <field name="payment_memo"
                                           placeholder="Règlement {invoice_number}"/>
                                </group>
                                <div class="text-muted small mt-1">
                                    Variables disponibles dans le mémo :
                                    <code>{invoice_number}</code>,
                                    <code>{contract_number}</code>,
                                    <code>{partner}</code>
                                </div>
                            </group>

                        </page>

                    </notebook>
                </sheet>

                <!-- Chatter : historique des emails reçus -->
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Vue liste ─────────────────────────────────────────────────────── -->

    <record id="view_supplier_email_rule_tree" model="ir.ui.view">
        <field name="name">supplier.email.rule.tree</field>
        <field name="model">supplier.email.rule</field>
        <field name="arch" type="xml">
            <tree string="Règles de parsing email">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="alias_id"/>
                <field name="use_pdf_attachment" optional="show"/>
                <field name="auto_post_bill" optional="show"/>
                <field name="auto_register_payment" optional="show"/>
                <field name="last_import_date"/>
                <field name="last_import_result"/>
                <field name="bill_count" string="Factures"/>
                <field name="active" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- ── Action ────────────────────────────────────────────────────────── -->

    <record id="action_supplier_email_rule" model="ir.actions.act_window">
        <field name="name">Règles import email fournisseurs</field>
        <field name="res_model">supplier.email.rule</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créez votre première règle de parsing
            </p>
            <p>
                Chaque règle crée automatiquement un alias email Odoo.
                Configurez un transfert automatique dans votre messagerie
                vers cet alias pour une comptabilisation 100% automatique.
            </p>
        </field>
    </record>

</odoo>
