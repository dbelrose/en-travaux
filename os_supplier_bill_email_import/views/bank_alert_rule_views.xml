<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════
         Règles d'alerte bancaire — Vue formulaire
    ════════════════════════════════════════════════════════════════════════ -->

    <record id="view_bank_alert_rule_form" model="ir.ui.view">
        <field name="name">bank.alert.email.rule.form</field>
        <field name="model">bank.alert.email.rule</field>
        <field name="arch" type="xml">
            <form string="Règle de parsing alerte bancaire">
                <sheet>
                    <widget name="web_ribbon" title="Archivé"
                            bg_color="text-bg-danger"
                            invisible="active"/>

                    <!-- Smart button -->
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_statement_lines"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-university"
                                invisible="statement_line_count == 0">
                            <field name="statement_line_count"
                                   string="Lignes relevé"
                                   widget="statinfo"/>
                        </button>
                    </div>

                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name"
                                   placeholder="Ex : Alerte Marara Paiement XPF"/>
                        </h1>
                    </div>

                    <!-- Indicateur dernier import -->
                    <div class="alert alert-info" role="alert"
                         invisible="not last_import_date">
                        <strong>Dernier import :</strong>
                        <field name="last_import_result" readonly="1"/>
                        (<field name="last_import_date" widget="datetime" readonly="1"/>)
                    </div>

                    <notebook>

                        <!-- ══════════════════════════════════════════════
                             Onglet 1 — Général
                        ═══════════════════════════════════════════════════ -->
                        <page string="Général" name="general">

                            <!-- Alias email -->
                            <group string="📬 Adresse email de réception automatique">
                                <div class="alert alert-info" role="alert">
                                    <p>
                                        Configurez un <strong>transfert automatique</strong>
                                        dans votre messagerie pour rediriger les alertes
                                        de votre banque vers l'adresse ci-dessous.
                                    </p>
                                    <p>
                                        Chaque email d'alerte reçu sera analysé et les
                                        opérations créditées / débitées seront
                                        <strong>enregistrées automatiquement</strong>
                                        dans le journal bancaire sélectionné.
                                    </p>
                                </div>
                                <field name="alias_id"
                                       widget="mail_alias_setting"
                                       string="Alias email"/>
                            </group>

                            <group>
                                <group string="Identification de l'email (sécurité)">
                                    <field name="active" invisible="1"/>
                                    <field name="sequence"/>
                                    <field name="sender_email_pattern"
                                           placeholder="no-reply@mararapaiement\.pf"/>
                                    <field name="subject_pattern"
                                           placeholder="Alerte sur votre compte (optionnel)"/>
                                </group>
                                <group string="Comptabilité">
                                    <field name="journal_id"/>
                                    <field name="currency_code"/>
                                </group>
                            </group>

                            <!-- Vérification n° de compte -->
                            <group string="Vérification du numéro de compte (optionnel)">
                                <div class="alert alert-secondary" role="alert">
                                    Si votre messagerie reçoit des alertes pour
                                    <strong>plusieurs comptes bancaires</strong>,
                                    configurez ici la regex et le numéro attendu
                                    pour que chaque règle ne traite que son propre compte.
                                </div>
                                <group>
                                    <field name="regex_account_number"
                                           placeholder="compte\s+\w+\s+\(([\w\-]+)\s+XPF\)"/>
                                    <field name="expected_account_number"
                                           placeholder="00001-2510504C068-36"/>
                                </group>
                            </group>

                        </page>

                        <!-- ══════════════════════════════════════════════
                             Onglet 2 — Regex de parsing
                        ═══════════════════════════════════════════════════ -->
                        <page string="Expression régulière" name="regex">

                            <group string="Extraction des opérations bancaires">
                                <div class="alert alert-secondary" role="alert">
                                    <p>
                                        La regex est appliquée en mode
                                        <strong>finditer</strong> (toutes les occurrences)
                                        sur le corps texte de l'email d'alerte.
                                    </p>
                                    <p>
                                        Elle doit avoir <strong>4 groupes capturants</strong> :
                                    </p>
                                    <ol>
                                        <li><strong>Groupe 1</strong> — date (JJ/MM/AAAA)</li>
                                        <li><strong>Groupe 2</strong> — sens (débit / crédit)</li>
                                        <li><strong>Groupe 3</strong> — montant (chiffres + séparateurs)</li>
                                        <li><strong>Groupe 4</strong> — libellé de l'opération</li>
                                    </ol>
                                    <p>
                                        <strong>Exemple Marara Paiement :</strong><br/>
                                        Email : <em>« Le 03/03/2026, débit de 3 354 XPF PRELEVEMENT, »</em><br/>
                                        <code>Le\s+(\d{{2}}/\d{{2}}/\d{{4}}),\s+(d[ée]bit|cr[ée]dit)\s+de\s+([\d\s\u00a0\u202f,\.]+?)\s*(?:XPF|FCFP)\s+([A-Z][A-Z\s]+?)(?=\s*[,&lt;\n]|$)</code>
                                    </p>
                                </div>
                                <field name="regex_transaction"
                                       widget="char"
                                       style="font-family: monospace;"
                                       placeholder="Le\s+(\d{2}/\d{2}/\d{4}),\s+(d[ée]bit|cr[ée]dit)\s+de\s+([\d\s,\.]+?)\s*(?:XPF|FCFP)\s+([A-Z][A-Z\s]+?)(?=\s*[,&lt;\n]|$)"/>
                            </group>

                        </page>

                        <!-- ══════════════════════════════════════════════
                             Onglet 3 — Rapprochement automatique
                        ═══════════════════════════════════════════════════ -->
                        <page string="Rapprochement automatique" name="reconcile">

                            <group string="Paramètres du rapprochement">
                                <div class="alert alert-warning" role="alert">
                                    <strong>⚠ À utiliser avec précaution.</strong><br/>
                                    Le rapprochement automatique ne fonctionne que pour les
                                    opérations dont le <strong>montant correspond exactement</strong>
                                    à une pièce comptable ouverte unique.<br/><br/>
                                    En cas de doublons de montant ou de pièce introuvable,
                                    la ligne reste non rapprochée et doit être traitée
                                    manuellement depuis le tableau de bord bancaire.
                                </div>
                                <group>
                                    <field name="auto_reconcile"/>
                                    <field name="reconcile_partner_id"
                                           invisible="not auto_reconcile"/>
                                    <field name="reconcile_label_filter"
                                           invisible="not auto_reconcile"
                                           placeholder="PRELEVEMENT"/>
                                </group>
                            </group>

                            <group string="Flux de rapprochement" invisible="not auto_reconcile">
                                <div class="alert alert-info" role="alert">
                                    <strong>Flux pour un débit (prélèvement) :</strong>
                                    <ol>
                                        <li>La ligne de relevé est créée dans le journal bancaire.</li>
                                        <li>Odoo génère l'écriture comptable avec un compte de suspense.</li>
                                        <li>Le module cherche une pièce fournisseur
                                            <strong>ouverte</strong> dont le
                                            <code>amount_residual</code> = montant du débit.</li>
                                        <li>Si une unique correspondance est trouvée :
                                            rapprochement automatique ✔</li>
                                        <li>Sinon : ligne en attente de rapprochement manuel.</li>
                                    </ol>
                                    <strong>Flux pour un crédit :</strong> idem avec les pièces clients ouvertes.
                                </div>
                            </group>

                        </page>

                    </notebook>
                </sheet>

                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Vue liste ──────────────────────────────────────────────────────── -->

    <record id="view_bank_alert_rule_tree" model="ir.ui.view">
        <field name="name">bank.alert.email.rule.tree</field>
        <field name="model">bank.alert.email.rule</field>
        <field name="arch" type="xml">
            <tree string="Règles d'alerte bancaire">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="journal_id"/>
                <field name="alias_id"/>
                <field name="auto_reconcile" optional="show"/>
                <field name="last_import_date"/>
                <field name="last_import_result"/>
                <field name="statement_line_count" string="Lignes relevé"/>
                <field name="active" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- ── Action ─────────────────────────────────────────────────────────── -->

    <record id="action_bank_alert_rule" model="ir.actions.act_window">
        <field name="name">Règles import alertes bancaires</field>
        <field name="res_model">bank.alert.email.rule</field>
        <field name="view_mode">tree,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Créez votre première règle d'alerte bancaire
            </p>
            <p>
                Configurez un transfert automatique de vos alertes bancaires
                vers l'alias Odoo pour une comptabilisation sans intervention.
            </p>
        </field>
    </record>

</odoo>
