<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ============================================================
             MENUS DU SITE WEB BELROSE PLACE
             noupdate="1" : les menus ne sont recréés qu'à l'installation
        ============================================================ -->

        <!-- Menu racine -->
        <record id="website_menu_root" model="website.menu">
            <field name="name">Top Menu</field>
            <field name="url">/</field>
            <field name="website_id" ref="website.default_website"/>
            <field name="sequence">0</field>
        </record>

        <!-- Accueil -->
        <record id="website_menu_home" model="website.menu">
            <field name="name">Accueil</field>
            <field name="url">/</field>
            <field name="website_id" ref="website.default_website"/>
            <field name="parent_id" ref="website_menu_root"/>
            <field name="sequence">10</field>
        </record>

        <!-- Réservation -->
        <record id="website_menu_reservation" model="website.menu">
            <field name="name">Réserver</field>
            <field name="url">/reservation</field>
            <field name="website_id" ref="website.default_website"/>
            <field name="parent_id" ref="website_menu_root"/>
            <field name="sequence">20</field>
        </record>

        <!-- Chèque cadeau vacances -->
        <record id="website_menu_cheque_cadeau" model="website.menu">
            <field name="name">Chèque cadeau vacances</field>
            <field name="url">/cheque-cadeau-vacances</field>
            <field name="website_id" ref="website.default_website"/>
            <field name="parent_id" ref="website_menu_root"/>
            <field name="sequence">30</field>
        </record>

        <!-- Contactez-nous -->
        <record id="website_menu_contact" model="website.menu">
            <field name="name">Contactez-nous</field>
            <field name="url">/contactus</field>
            <field name="website_id" ref="website.default_website"/>
            <field name="parent_id" ref="website_menu_root"/>
            <field name="sequence">40</field>
        </record>

    </data>
</odoo>
