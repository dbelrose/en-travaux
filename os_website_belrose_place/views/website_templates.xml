<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         TEMPLATE DE BASE BELROSE PLACE
         Hérite du layout Odoo website standard
    ============================================================ -->
    <template id="belrose_base" name="Belrose Place - Base">
        <t t-call="website.layout">
            <t t-set="head">
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <meta name="description" content="Belrose Place Tahiti - Location saisonnière à Punaauia. Appartements de 4 à 9 chambres avec vue sur l'océan et Moorea."/>
                <link rel="preconnect" href="https://fonts.googleapis.com"/>
                <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin=""/>
                <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&amp;family=Lato:wght@300;400;700&amp;display=swap"
                      rel="stylesheet"/>
            </t>
            <t t-out="0"/>
        </t>
    </template>

</odoo>
