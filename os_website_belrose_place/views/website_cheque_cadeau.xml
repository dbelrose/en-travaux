<?xml version="1.0" encoding="utf-8"?>
<odoo>
<template id="cheque_cadeau_vacances" name="Belrose Place - Chèque Cadeau Vacances">
    <t t-call="website.layout">
        <div id="wrap" class="belrose-page">

            <section class="bp-page-hero">
                <div class="bp-container">
                    <div class="bp-eyebrow">Offrir un séjour</div>
                    <h1 class="bp-page-title">
                        Chèque Cadeau<br/><em>Vacances</em>
                    </h1>
                    <p class="bp-page-subtitle">
                        Offrez un séjour inoubliable à Belrose Place Tahiti ·
                        Give an unforgettable stay at Belrose Place Tahiti
                    </p>
                </div>
            </section>

            <section class="bp-section" style="background:var(--bp-obsidian)">
                <div class="bp-container">

                    <div class="bp-cheque-grid">
                        <div class="bp-info-card">
                            <h3>📋 Conditions d'utilisation</h3>
                            <p>
                                Le chèque cadeau vacances est valable <strong style="color:var(--bp-white)">1 an</strong>.
                                Il est cumulable, utilisable en une ou plusieurs fois, comme un avoir
                                qui vient en déduction du prix que vous aurez à payer, pour réserver
                                un séjour à Belrose Place.
                            </p>
                            <div class="bp-warning">
                                <strong>⚠️ Attention</strong> — il n'est pas remboursable,
                                de même que le reliquat éventuel.
                            </div>
                            <p>Les frais de traitement sont inclus dans le montant en euros.</p>
                        </div>

                        <div class="bp-info-card is-en">
                            <h3>📋 Terms of Use</h3>
                            <p>
                                The vacation gift voucher is valid for <strong style="color:var(--bp-white)">1 year</strong>.
                                It can be combined and used in one or several times, as a credit
                                that is deducted from the price you will have to pay to book a
                                stay at Belrose Place.
                            </p>
                            <div class="bp-warning">
                                <strong>⚠️ Please note</strong> — it is not refundable,
                                nor is any remaining balance.
                            </div>
                            <p>Processing fees are included in the euro amount.</p>
                        </div>

                        <div class="bp-info-card">
                            <h3>🎁 Pourquoi nos chèques cadeaux ?</h3>
                            <ul class="bp-checklist">
                                <li>Flexibilité totale : utilisable quand vous le souhaitez</li>
                                <li>Cumulable : combinez plusieurs chèques</li>
                                <li>Valable 1 an : le temps de planifier</li>
                                <li>Cadeau parfait : pour toutes les occasions</li>
                                <li>Expérience unique : à Tahiti</li>
                            </ul>
                        </div>

                        <div class="bp-info-card is-en">
                            <h3>🎁 Why choose our gift vouchers?</h3>
                            <ul class="bp-checklist">
                                <li>Total flexibility: use whenever you want</li>
                                <li>Combinable: combine multiple vouchers</li>
                                <li>Valid for 1 year: time to plan</li>
                                <li>Perfect gift: for all occasions</li>
                                <li>Unique experience: in Tahiti</li>
                            </ul>
                        </div>
                    </div>

                    <div class="bp-cta-row">
                        <div class="bp-cta-card">
                            <h3>🛒 Achetez votre chèque cadeau</h3>
                            <p>Sélectionnez le montant et finalisez votre achat en ligne</p>
                            <a href="https://www.billetweb.fr/shop.php?event=cheque-cadeau-vacances"
                               target="_blank" rel="noopener noreferrer"
                               class="bp-btn-primary">
                                <span>Acheter maintenant</span>
                            </a>
                        </div>
                        <div class="bp-cta-card">
                            <h3>🛒 Buy your gift voucher</h3>
                            <p>Select the amount and complete your online purchase</p>
                            <a href="https://www.billetweb.fr/shop.php?event=cheque-cadeau-vacances"
                               target="_blank" rel="noopener noreferrer"
                               class="bp-btn-ghost">
                                <span>Buy now</span>
                            </a>
                        </div>
                    </div>

                    <div class="text-center mt-5">
                        <a href="/" class="bp-btn-ghost">← Retour à l'accueil</a>
                    </div>

                </div>
            </section>
        </div>
    </t>
</template>
</odoo>
