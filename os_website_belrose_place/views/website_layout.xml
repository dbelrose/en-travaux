<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============================================================
         HEADER — Navbar fixe avec logo + menu + burger mobile
    ============================================================ -->
    <template id="belrose_layout_header" name="Belrose Place - Header"
              inherit_id="website.layout" primary="True">
        <xpath expr="//header" position="replace">
            <header>
                <nav class="belrose-navbar" id="belroseNavbar">
                    <div class="container">
                        <a class="belrose-nav-brand" href="/">
                            <img src="/web/image/website/1/logo/belroseplacetahiti"
                                 alt="Belrose Place Tahiti"
                                 class="belrose-logo"
                                 onerror="this.style.display='none'"/>
                        </a>

                        <ul class="belrose-nav-links" id="belroseNavLinks">
                            <li class="nav-item"><a class="nav-link" href="/">Accueil</a></li>
                            <li class="nav-item"><a class="nav-link bp-btn-reserve" href="/reservation">Réserver</a></li>
                            <li class="nav-item"><a class="nav-link" href="/cheque-cadeau-vacances">Chèque cadeau</a></li>
                            <li class="nav-item"><a class="nav-link" href="/contactus">Contact</a></li>
                        </ul>

                        <button class="belrose-burger" id="belroseBurger" aria-label="Menu">
                            <span/><span/><span/>
                        </button>
                    </div>
                </nav>
            </header>
        </xpath>
    </template>

    <!-- ============================================================
         FOOTER — Colonnes informatives + bas de page
    ============================================================ -->
    <template id="belrose_layout_footer" name="Belrose Place - Footer"
              inherit_id="website.layout">
        <xpath expr="//footer" position="replace">
            <footer class="belrose-footer">
                <div class="bp-container">
                    <div class="bp-footer-main">
                        <div class="row">

                            <div class="col-md-4 col-sm-6 mb-4 bp-footer-brand">
                                <img src="/web/image/website/1/logo/belroseplacetahiti"
                                     alt="Belrose Place" class="belrose-logo"
                                     onerror="this.style.display='none'"/>
                                <p class="bp-footer-tagline">
                                    Location saisonnière d'exception<br/>
                                    à Punaauia, Tahiti
                                </p>
                                <div class="bp-footer-social">
                                    <a href="https://www.facebook.com/profile.php?id=61561318565430"
                                       target="_blank" rel="noopener noreferrer"
                                       class="bp-social-btn" aria-label="Facebook">
                                        <i class="fa fa-facebook"/>
                                    </a>
                                </div>
                            </div>

                            <div class="col-md-2 col-sm-6 mb-4 bp-footer-col">
                                <h6>Navigation</h6>
                                <ul class="bp-footer-links">
                                    <li><a href="/">Accueil</a></li>
                                    <li><a href="#gallery">Galerie</a></li>
                                    <li><a href="#apartments">Appartements</a></li>
                                    <li><a href="/reservation">Réserver</a></li>
                                    <li><a href="#partners">Partenaires</a></li>
                                </ul>
                            </div>

                            <div class="col-md-3 col-sm-6 mb-4 bp-footer-col">
                                <h6>Services</h6>
                                <ul class="bp-footer-links">
                                    <li><a href="/cheque-cadeau-vacances">Chèque cadeau vacances</a></li>
                                    <li><a href="https://www.maruiatahiti.site" target="_blank" rel="noopener noreferrer">Massages Maruia</a></li>
                                    <li><a href="/contactus">Nous contacter</a></li>
                                </ul>
                            </div>

                            <div class="col-md-3 col-sm-6 mb-4 bp-footer-col bp-footer-contact">
                                <h6>Contact</h6>
                                <a href="tel:+68987002407">
                                    <i class="fa fa-phone"/> 87 00 24 07
                                </a>
                                <a href="mailto:belroseplacetahiti@gmail.com">
                                    <i class="fa fa-envelope"/> belroseplacetahiti@gmail.com
                                </a>
                                <p style="font-size:0.82rem;color:rgba(255,255,255,0.4);margin-top:0.75rem">
                                    Résidence Flamboyant, Punavai Nui<br/>Punaauia, Tahiti
                                </p>
                            </div>

                        </div>
                    </div>

                    <div class="bp-footer-bottom">
                        <p>© 2025 Belrose Place — Tous droits réservés</p>
                        <div style="display:flex;gap:1.5rem;align-items:center;flex-wrap:wrap">
                            <a href="/mentions-legales">Mentions légales</a>
                            <span style="color:rgba(255,255,255,0.15)">|</span>
                            <a href="https://opalsea.site" target="_blank" rel="noopener noreferrer">
                                Site créé avec ❤️ par OpalSea
                            </a>
                        </div>
                    </div>
                </div>
            </footer>
        </xpath>
    </template>

</odoo>
