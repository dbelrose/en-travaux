<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="survey_form_inherit" model="ir.ui.view">
            <field name="name">PF: survey</field>
            <field name="model">survey.survey</field>
            <!-- survey.survey_form renommé en survey.survey_survey_view_form en v18 -->
            <field name="inherit_id" ref="survey.survey_survey_view_form"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <header>
                    <!--
                        En v14 : attrs invisible basé sur session_state, state='open', certification
                        En v18 : le champ 'state' n'existe plus sur survey.survey
                                 On utilise 'active' à la place
                    -->
                    <button name="action_start_survey"
                            string="Démarrer"
                            type="object"
                            invisible="session_state or not active or certification"/>
                </header>
                <xpath expr="//notebook" position="before">
                    <div>
                        <div>
                            <group colspan="8" col="4">
                                <field
                                    name="company_id"
                                    groups="base.group_multi_company"
                                    options="{'no_create': True}"
                                />
                            </group>
                        </div>
                        <div>
                            <group colspan="8" col="4">
                                <field name="code"/>
                            </group>
                        </div>
                    </div>
                </xpath>
            </field>
        </record>

        <record id="survey_kanban_start" model="ir.ui.view">
            <field name="name">survey.kanban_start</field>
            <field name="model">survey.survey</field>
            <!-- survey.survey_kanban renommé en survey.survey_survey_view_kanban en v18 -->
            <field name="inherit_id" ref="survey.survey_survey_view_kanban"/>
            <field name="priority" eval="8"/>
            <field name="arch" type="xml">
                <xpath expr="//div[@role='separator']" position="before">
                    <!--
                        En v14 : record.state.raw_value == 'open'
                        En v18 : pas de champ state sur survey, on utilise active
                    -->
                    <a t-if="record.active.raw_value and not record.session_state.raw_value"
                       role="menuitem"
                       type="object"
                       class="dropdown-item"
                       name="action_start_survey">Démarrer</a>
                </xpath>
            </field>
        </record>
    </data>
</odoo>