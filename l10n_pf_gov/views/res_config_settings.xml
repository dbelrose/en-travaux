<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Compléter la vue des paramètres généraux -->
        <record id="view_res_config_settings_view_form_inherit_inactivity" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.inactivity</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
            <field name="arch" type="xml">
<!--                <xpath expr="//div[@id='access_rights']" position="after">-->
                <xpath expr="//field[@name='active_user_count']" position="before">
                    <group>
                        <field name="inactivity_days"/>
                    </group>
                </xpath>
            </field>
        </record>
    </data>
</odoo>