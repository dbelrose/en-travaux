<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Modèle d'email pour l'archivage des utilisateurs inactifs -->
        <record id="email_template_archive_inactive_users" model="mail.template">
            <field name="name">Notification d'archivage des utilisateurs inactifs</field>
            <field name="model_id" ref="base.model_res_users" />
            <field name="subject">Votre compte Odoo a été archivé</field>
            <field name="email_from">${(object.email or 'admin.odoo.dsi@administration.gov.pf')|safe}</field>
            <field name="partner_to">${object.partner_id.id}</field>
            <field name="lang">${object.partner_id.lang}</field>
            <field name="auto_delete" eval="True" />
            <field name="body_html">
                <![CDATA[
                <p>Ia ora na ${object.name},</p>
                <p>Votre compte Odoo a été archivé car vous n'y avez pas accédé depuis plus de ${ctx.get('inactivity_days')} jours.</p>
                <p>Si vous souhaitez réactiver votre compte, veuillez en faire la demande à votre correspondant Odoo.</p>
                <p>Mauruuru,</p>
                <p>L'équipe Odoo</p>
                ]]>
            </field>
        </record>

        <!-- Modèle d'email pour les alertes d'inactivité -->
        <record id="email_template_alert_inactive_users" model="mail.template">
            <field name="name">Alerte d'inactivité des utilisateurs</field>
            <field name="model_id" ref="base.model_res_users" />
            <field name="subject">Alerte : Votre compte Odoo sera désactivé bientôt</field>
            <field name="email_from">${(object.email or 'admin.odoo.dsi@administration.gov.pf')|safe}</field>
            <field name="partner_to">${object.partner_id.id}</field>
            <field name="lang">${object.partner_id.lang}</field>
            <field name="auto_delete" eval="True" />
            <field name="body_html">
                <![CDATA[
                <p>Ia ora na ${object.name},</p>
                <p>Nous avons remarqué que vous ne vous êtes pas connecté depuis un certain temps. Veuillez vous connecter à votre compte avant ${ctx.get('days_before')} jours pour éviter la désactivation de votre compte.</p>
                <p>Adresse de connexion : <a href="https://www.gestion.gov.pf/web/login">https://www.gestion.gov.pf/web/login</a></p>
                <p>Il vous reste ${ctx.get('days_before')} jours avant la désactivation de votre compte.</p>
                <p>Mauruuru,</p>
                <p>L'équipe Odoo</p>
                ]]>
            </field>
        </record>
    </data>
</odoo>