<odoo>
    <data noupdate="1">
        <!-- Tâche cron pour archiver les utilisateurs inactifs -->
        <record id="ir_cron_archive_inactive_users" model="ir.cron">
            <field name="name">Archive Inactive Users</field>
            <field name="model_id" ref="base.model_res_users"/>
            <field name="state">code</field>
            <field name="code">model.archive_inactive_users()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">months</field>
        </record>
    </data>
</odoo>