<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ========================================= -->
    <!-- VUES BOOKING.YEAR -->
    <!-- ========================================= -->

    <!-- Vue formulaire booking.year -->
    <record id="view_booking_year_form" model="ir.ui.view">
        <field name="name">booking.year.form</field>
        <field name="model">booking.year</field>
        <field name="arch" type="xml">
            <form string="Déclaration annuelle de CA">
                <header>
                    <button name="action_recalculate"
                            string="⚙️ Recalculer"
                            type="object"
                            class="btn-secondary"/>
                    <button name="action_confirm"
                            string="✅ Confirmer"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_declare"
                            string="📋 Déclarer"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'confirmed'"/>
                    <button name="action_export_pdf_data"
                            string="📄 Exporter données PDF"
                            type="object"
                            class="btn-warning"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,declared"/>
                </header>

                <sheet>
                    <div class="oe_title">
                        <h1><field name="display_name" readonly="1"/></h1>
                    </div>

                    <group>
                        <group string="Identification">
                            <field name="year"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Chiffre d'affaires">
                            <field name="total_revenue" widget="monetary"/>
                            <field name="ligne_19" string="CA formaté (PDF)"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="📋 Données formulaire PDF" name="pdf_data">
                            <group>
                                <group string="Période">
                                    <field name="annee" readonly="1"/>
                                    <field name="date_debut" readonly="1"/>
                                    <field name="date_fin" readonly="1"/>
                                    <field name="date" readonly="1" string="Date déclaration"/>
                                </group>
                                <group string="Privilège">
                                    <field name="privilege_oui" readonly="1"/>
                                    <field name="privilege_non" readonly="1"/>
                                </group>
                            </group>

                            <separator string="Lignes financières"/>
                            <group>
                                <group>
                                    <field name="ligne_17" readonly="1"/>
                                    <field name="ligne_19" readonly="1" string="CA annuel"/>
                                    <field name="ligne_a_p_c" readonly="1" string="Ligne A (P.C)"/>
                                    <field name="ligne_b_p_d" readonly="1" string="Ligne B (P.D)"/>
                                </group>
                                <group>
                                    <field name="ligne_c" readonly="1"/>
                                    <field name="ligne_d" readonly="1"/>
                                    <field name="ligne_dx" readonly="1"/>
                                    <field name="ligne_17_commentaire" readonly="1"/>
                                </group>
                            </group>

                            <separator string="Informations déclarant"/>
                            <group>
                                <group string="Identité">
                                    <field name="nom_prenom" readonly="1"/>
                                    <field name="date_naissance" readonly="1"/>
                                    <field name="raison_sociale" readonly="1"/>
                                </group>
                                <group string="Contact">
                                    <field name="email" readonly="1"/>
                                    <field name="telephone" readonly="1"/>
                                    <field name="numero_tahiti" readonly="1"/>
                                    <field name="numero_tahiti_2" readonly="1"/>
                                </group>
                            </group>

                            <separator string="Localisation"/>
                            <group>
                                <group>
                                    <field name="lieu" readonly="1"/>
                                    <field name="activite" readonly="1"/>
                                </group>
                                <group>
                                    <field name="adresse_geo_1" readonly="1"/>
                                    <field name="adresse_geo_2" readonly="1" string=""/>
                                    <field name="adresse_geo_3" readonly="1" string=""/>
                                    <field name="adresse_pos" readonly="1"/>
                                </group>
                            </group>
                        </page>

                        <page string="📊 Détails" name="details">
                            <group>
                                <field name="total_revenue" widget="monetary" string="CA total annuel"/>
                            </group>
                            <separator string="Aperçu des données"/>
                            <div class="alert alert-info">
                                <p><strong>Année:</strong> <field name="annee" readonly="1" nolabel="1"/></p>
                                <p><strong>Période:</strong> <field name="date_debut" readonly="1" nolabel="1"/> - <field name="date_fin" readonly="1" nolabel="1"/></p>
                                <p><strong>CA annuel:</strong> <field name="ligne_19" readonly="1" nolabel="1"/> XPF</p>
                                <p><strong>Activité:</strong> <field name="activite" readonly="1" nolabel="1"/></p>
                                <p><strong>Déclarant:</strong> <field name="nom_prenom" readonly="1" nolabel="1"/></p>
                            </div>
                        </page>

                        <page string="💾 Export JSON" name="json_export">
                            <div class="alert alert-warning">
                                <p><strong>Note:</strong> Ces données sont formatées pour être exportées vers un système de remplissage de PDF.</p>
                                <p>Cliquez sur le bouton "📄 Exporter données PDF" en haut pour obtenir le dictionnaire complet.</p>
                            </div>
                            <group>
                                <group string="Exemple de structure">
                                    <p>
                                        {<br/>
                                        "annee": "<field name="annee" readonly="1" nolabel="1"/>",<br/>
                                        "ligne_19": "<field name="ligne_19" readonly="1" nolabel="1"/>",<br/>
                                        "nom_prenom": "<field name="nom_prenom" readonly="1" nolabel="1"/>",<br/>
                                        ...<br/>
                                        }
                                    </p>
                                </group>
                            </group>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Vue liste booking.year -->
    <record id="view_booking_year_tree" model="ir.ui.view">
        <field name="name">booking.year.tree</field>
        <field name="model">booking.year</field>
        <field name="arch" type="xml">
            <tree string="Déclarations annuelles">
                <field name="display_name"/>
                <field name="year"/>
                <field name="total_revenue"
                       sum="Total CA"
                       widget="monetary"/>
                <field name="ligne_19"
                       string="CA formaté (PDF)"/>
                <field name="activite" optional="hide"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="company_currency_id" column_invisible="1"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'confirmed'"
                       decoration-warning="state == 'declared'"/>
                <button name="action_recalculate"
                        string="⚙️ Recalculer"
                        type="object"
                        icon="fa-refresh"/>
            </tree>
        </field>
    </record>

    <!-- Vue recherche booking.year -->
    <record id="view_booking_year_search" model="ir.ui.view">
        <field name="name">booking.year.search</field>
        <field name="model">booking.year</field>
        <field name="arch" type="xml">
            <search string="Rechercher déclarations annuelles">
                <field name="year"/>
                <field name="company_id" groups="base.group_multi_company"/>

                <separator/>
                <filter string="Année en cours"
                        name="current_year"
                        domain="[('year', '=', context_today().year)]"/>
                <filter string="Année précédente"
                        name="previous_year"
                        domain="[('year', '=', context_today().year - 1)]"/>

                <separator/>
                <filter string="Brouillon"
                        name="draft"
                        domain="[('state', '=', 'draft')]"/>
                <filter string="Confirmé"
                        name="confirmed"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter string="Déclaré"
                        name="declared"
                        domain="[('state', '=', 'declared')]"/>

                <separator/>
                <group expand="0" string="Grouper par">
                    <filter string="Année" name="group_year" context="{'group_by': 'year'}"/>
                    <filter string="État" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Société" name="group_company" context="{'group_by': 'company_id'}" groups="base.group_multi_company"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Vue kanban booking.year -->
    <record id="view_booking_year_kanban" model="ir.ui.view">
        <field name="name">booking.year.kanban</field>
        <field name="model">booking.year</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile">
                <field name="display_name"/>
                <field name="year"/>
                <field name="total_revenue"/>
                <field name="ligne_19"/>
                <field name="state"/>
                <field name="activite"/>
                <field name="company_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="o_kanban_card_header">
                                <div class="o_kanban_card_header_title">
                                    <div class="o_primary">
                                        <strong><t t-out="record.year.value"/> - <t t-out="record.company_id.value"/></strong>
                                    </div>
                                </div>
                            </div>
                            <div class="o_kanban_card_content">
                                <div><strong>CA annuel:</strong> <t t-out="record.ligne_19.value"/> XPF</div>
                                <div><strong>Activité:</strong> <t t-out="record.activite.value"/></div>
                            </div>
                            <div class="o_kanban_card_footer">
                                <span class="badge"
                                      t-att-class="record.state.value == 'declared' ? 'badge-success' :
                                                   record.state.value == 'confirmed' ? 'badge-info' : 'badge-secondary'">
                                    <t t-out="record.state.value"/>
                                </span>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Action booking.year -->
    <record id="action_booking_year" model="ir.actions.act_window">
        <field name="name">Déclarations annuelles</field>
        <field name="res_model">booking.year</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="context">{
            'search_default_previous_year': 1,
        }</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Aucune déclaration annuelle trouvée
            </p>
            <p>
                Les déclarations annuelles cumulent le chiffre d'affaires de toutes les propriétés par année et par société.
                Elles servent à remplir les formulaires PDF de déclaration fiscale.
            </p>
            <p>
                Cliquez sur "Créer" pour générer une nouvelle déclaration annuelle.
            </p>
        </field>
    </record>

    <!-- Menu -->
    <menuitem id="menu_booking_year"
              name="Déclarations annuelles"
              parent="menu_hospitality_root"
              action="action_booking_year"
              sequence="40"/>
</odoo>
