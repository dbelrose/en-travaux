<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wizard_bordereau_form" model="ir.ui.view">
        <field name="name">cps.wizard.bordereau.form</field>
        <field name="model">cps.wizard.bordereau</field>
        <field name="arch" type="xml">
            <form string="Générer un bordereau mensuel">
                <group>
                    <group string="Paramètres">
                        <field name="praticien_id"/>
                        <field name="mois"/>
                        <field name="annee"/>
                    </group>
                </group>
                <group string="Feuilles de soins à inclure">
                    <field name="feuille_ids" nolabel="1">
                        <tree>
                            <field name="name"/>
                            <field name="patient_id"/>
                            <field name="patient_dn"/>
                            <field name="date_debut_soins"/>
                            <field name="date_fin_soins"/>
                            <field name="montant_tiers_payant"/>
                            <field name="montant_patient"/>
                            <field name="montant_total"/>
                        </tree>
                    </field>
                </group>
                <footer>
                    <button name="action_generate" string="Générer le bordereau"
                            type="object" class="btn-primary"/>
                    <button string="Annuler" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wizard_bordereau" model="ir.actions.act_window">
        <field name="name">Générer un bordereau</field>
        <field name="res_model">cps.wizard.bordereau</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_wizard_bordereau" name="Générer un bordereau"
              parent="menu_cps_main" action="action_wizard_bordereau" sequence="30"/>
</odoo>
