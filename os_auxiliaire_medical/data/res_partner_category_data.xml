<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <!-- ── Catégorie racine Prescripteur ─────────────────────────────── -->
        <record id="partner_category_prescripteur" model="res.partner.category">
            <field name="name">Prescripteur</field>
            <field name="color">3</field>
        </record>

        <!-- ── Catégorie racine Patient ──────────────────────────────────── -->
        <record id="partner_category_patient" model="res.partner.category">
            <field name="name">Patient CPS</field>
            <field name="color">2</field>
        </record>

        <!-- ── Catégorie racine Praticien ────────────────────────────────── -->
        <record id="partner_category_praticien" model="res.partner.category">
            <field name="name">Praticien CPS</field>
            <field name="color">1</field>
        </record>

        <!-- ── Sous-catégories Professions (enfants de Praticien CPS) ────── -->
        <record id="partner_category_kinesitherapeute" model="res.partner.category">
            <field name="name">Masseur-kinésithérapeute</field>
            <field name="parent_id" ref="partner_category_praticien"/>
            <field name="color">1</field>
        </record>

        <record id="partner_category_orthophoniste" model="res.partner.category">
            <field name="name">Orthophoniste</field>
            <field name="parent_id" ref="partner_category_praticien"/>
            <field name="color">1</field>
        </record>

        <record id="partner_category_orthoptiste" model="res.partner.category">
            <field name="name">Orthoptiste</field>
            <field name="parent_id" ref="partner_category_praticien"/>
            <field name="color">1</field>
        </record>

        <record id="partner_category_pedicure" model="res.partner.category">
            <field name="name">Pédicure-Podologue</field>
            <field name="parent_id" ref="partner_category_praticien"/>
            <field name="color">1</field>
        </record>

        <record id="partner_category_infirmier" model="res.partner.category">
            <field name="name">Infirmier(e)</field>
            <field name="parent_id" ref="partner_category_praticien"/>
            <field name="color">1</field>
        </record>

        <record id="partner_category_autre_praticien" model="res.partner.category">
            <field name="name">Autre auxiliaire médical</field>
            <field name="parent_id" ref="partner_category_praticien"/>
            <field name="color">1</field>
        </record>

    </data>
</odoo>
