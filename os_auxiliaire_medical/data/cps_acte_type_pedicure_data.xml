        <!-- ────────────────────────────────────────────────────
             8.1.1 – ACTES DE PÉDICURIE
             Rééducations post-chirurgie de l'avant-pied
             (accord préalable)
        ──────────────────────────────────────────────────── -->

        <record id="acte_type_amp_reeducation_1pied" model="cps.acte.type">
            <!-- Code 08010101 -->
            <field name="name">Rééducation d'un pied (hors articulation tibio-tarsienne) post-chirurgie avant-pied – séance de 30 min – accord préalable</field>
            <field name="lettre_cle">AMP</field>
            <field name="coefficient_defaut">4</field>
            <field name="tarif_unitaire">283</field>
            <field name="profession">pedicure</field>
        </record>

        <record id="acte_type_amp_reeducation_2pieds" model="cps.acte.type">
            <!-- Code 08010102 -->
            <field name="name">Rééducation des deux pieds (hors articulations tibio-tarsiennes) post-chirurgie avant-pied – séance de 30 min – accord préalable</field>
            <field name="lettre_cle">AMP</field>
            <field name="coefficient_defaut">6</field>
            <field name="tarif_unitaire">283</field>
            <field name="profession">pedicure</field>
        </record>

        <record id="acte_type_amp_massage_1pied" model="cps.acte.type">
