<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="rule_acte_type_multi_company" model="ir.rule">
        <field name="name">Types d'actes NPAP – multi-company</field>
        <field name="model_id" ref="model_cps_acte_type"/>
        <field name="global" eval="True"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
    </record>

