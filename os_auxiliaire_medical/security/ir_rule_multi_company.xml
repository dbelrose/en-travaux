<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        Règles d'accès multi-company (ir.rule) pour le module os_auxiliaire_medical.
        Chaque règle restreint la visibilité des enregistrements aux sociétés
        accessibles par l'utilisateur courant (variable magique `company_ids`).

        Le pattern `('company_id', '=', False)` permet aux enregistrements
        partagés (ex : actes de nomenclature NPAP sans société) d'être visibles
        par tous les utilisateurs, quelle que soit leur société.
    -->

    <!-- ── cps.acte.type ─────────────────────────────────────────────────── -->
    <record id="rule_acte_type_multi_company" model="ir.rule">
        <field name="name">Types d'actes NPAP – multi-company</field>
        <field name="model_id" ref="model_cps_acte_type"/>
        <field name="global" eval="True"/>
        <field name="domain_force">
            ['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]
        </field>
    </record>

    <!-- ── cps.praticien ─────────────────────────────────────────────────── -->
    <record id="rule_praticien_multi_company" model="ir.rule">
        <field name="name">Praticiens – multi-company</field>
        <field name="model_id" ref="model_cps_praticien"/>
        <field name="global" eval="True"/>
        <field name="domain_force">
            [('company_id', 'in', company_ids)]
        </field>
    </record>

    <!-- ── cps.patient ───────────────────────────────────────────────────── -->
    <record id="rule_patient_multi_company" model="ir.rule">
        <field name="name">Patients – multi-company</field>
        <field name="model_id" ref="model_cps_patient"/>
        <field name="global" eval="True"/>
        <field name="domain_force">
            [('company_id', 'in', company_ids)]
        </field>
    </record>

    <!-- ── cps.feuille.soins ─────────────────────────────────────────────── -->
    <record id="rule_feuille_soins_multi_company" model="ir.rule">
        <field name="name">Feuilles de soins – multi-company</field>
        <field name="model_id" ref="model_cps_feuille_soins"/>
        <field name="global" eval="True"/>
        <field name="domain_force">
            [('company_id', 'in', company_ids)]
        </field>
    </record>

    <!-- ── cps.bordereau ─────────────────────────────────────────────────── -->
    <record id="rule_bordereau_multi_company" model="ir.rule">
        <field name="name">Bordereaux – multi-company</field>
        <field name="model_id" ref="model_cps_bordereau"/>
        <field name="global" eval="True"/>
        <field name="domain_force">
            [('company_id', 'in', company_ids)]
        </field>
    </record>

    <!-- ── cps.feuille.soins.modele ──────────────────────────────────────── -->
    <record id="rule_feuille_modele_multi_company" model="ir.rule">
        <field name="name">Modèles de feuilles – multi-company</field>
        <field name="model_id" ref="model_cps_feuille_soins_modele"/>
        <field name="global" eval="True"/>
        <field name="domain_force">
            [('company_id', 'in', company_ids)]
        </field>
    </record>

</odoo>
