<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!--
        model_id = cps.praticien : seul modèle du module qui a perm_write=1
        pour base.group_user. Odoo 17 vérifie check_access_rights('write') sur
        le model_id AVANT d'exécuter le code du server action — tous les autres
        modèles candidats (cps.acte.type, res.users) déclenchent une erreur
        d'accès pour les praticiens. cps.praticien est donc le bon choix.
        Le code utilise env['cps.acte.type'] explicitement.
    -->
    <record id="action_server_open_acte_type" model="ir.actions.server">
        <field name="name">Ouvrir Types d'actes (avec filtre profession)</field>
        <field name="model_id" ref="model_cps_praticien"/>
        <field name="state">code</field>
        <field name="code">
action = env['cps.acte.type'].action_open_acte_type()
        </field>
    </record>

</odoo>
