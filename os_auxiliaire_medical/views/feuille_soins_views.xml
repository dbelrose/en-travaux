<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_feuille_soins_form" model="ir.ui.view">
        <field name="name">cps.feuille.soins.form</field>
        <field name="model">cps.feuille.soins</field>
        <field name="arch" type="xml">
            <form string="Feuille de soins">
                <header>
                    <button name="action_confirm" string="Confirmer" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_submit" string="Soumettre à la CPS" type="object"
                            class="btn-primary" invisible="state != 'confirmed'"/>
                    <button name="action_paid" string="Marquer remboursée" type="object"
                            invisible="state != 'submitted'"/>
                    <button name="action_cancel" string="Annuler" type="object"
                            invisible="state in ('cancelled', 'paid')"/>
                    <button name="action_reset_draft" string="Remettre en brouillon" type="object"
                            invisible="state != 'cancelled'"/>
                    <button name="os_pdf_report_generator.pdf_report_4" string="Imprimer"
                            type="action" icon="fa-print"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,submitted,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="N° Facture"/>
                        <h1><field name="name" readonly="1"/></h1>
                        <label for="fsa_numero" string="N° FSA25"/>
                        <h3><field name="fsa_numero" readonly="1"/></h3>
                    </div>
                    <field name="photo_feuille" widget="image" class="oe_avatar"
                           options="{'preview_image': 'photo_feuille'}"/>

                    <!-- Ordonnance en amont -->
                    <group string="1 – Ordonnance (import automatique)">
                        <field name="ordonnance_id" domain="[('state', '=', 'active')]"
                               options="{'no_create': False}"
                               help="Sélectionnez l'ordonnance EN PREMIER : patient, praticien et prescription sont importés automatiquement."/>
                    </group>

                    <group>
                        <group string="2 – Bénéficiaire des soins">
                            <field name="patient_id"
                                   domain="[('category_id.name', '=', 'Patient CPS')]"
                                   options="{'quick_create': False}"
                                   readonly="ordonnance_id != False"/>
                            <field name="patient_dn" readonly="1" string="DN"/>
                        </group>
                        <group string="3 – Auxiliaire médical">
                            <field name="auxiliaire_remplacant"/>
                            <field name="praticien_id"
                                   domain="[('category_id.name', '=', 'Praticien CPS')]"
                                   readonly="not auxiliaire_remplacant"
                                   required="1"
                                   options="{'no_create': False}"/>
                            <field name="praticien_profession" invisible="1"/>
                            <field name="code_auxiliaire" readonly="1" string="Code auxiliaire"/>
                            <field name="accord_prealable" invisible="not auxiliaire_remplacant"/>
                            <field name="company_id" groups="base.group_multi_company"
                                   readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <group string="Modèle de saisie rapide" invisible="state != 'draft'">
                        <field name="modele_id" domain="[('profession', '=', praticien_profession)]"
                               options="{'no_create': False}"/>
                    </group>

                    <group>
                        <group string="Prescription">
                            <field name="parcours_soins"/>
                            <field name="code_prescripteur"/>
                            <field name="date_prescription"/>
                        </group>
                        <group string="Condition de prise en charge">
                            <field name="condition"/>
                            <field name="motif_derogation"
                                   invisible="condition != 'autre'"
                                   required="condition == 'autre'"
                                   placeholder="Précisez le motif…"/>
                            <field name="num_rsr"/>
                            <field name="num_panier"/>
                        </group>
                    </group>

                    <notebook>
                        <page string="Prestations des actes">
                            <div class="mb8" invisible="state != 'draft'">
                                <button name="action_open_date_wizard"
                                        string="📅 Ajouter des séances par sélection de dates"
                                        type="object" class="btn btn-secondary"/>
                            </div>
                            <field name="acte_ids">
                                <tree editable="bottom">
                                    <field name="acte_type_id"
                                           domain="[('profession', 'in', [False, parent.praticien_profession])]"
                                           optional="show" string="Acte (catalogue)"
                                           options="{'no_create': False}"/>
                                    <field name="date_acte"/>
                                    <field name="lettre_cle"/>
                                    <field name="coefficient"/>
                                    <field name="ifd"/>
                                    <field name="ik"/>
                                    <field name="dimanche_ferie"/>
                                    <field name="nuit"/>
                                    <field name="ordonnance_ligne_id" optional="show" string="Ord."/>
                                    <field name="seances_restantes" optional="show" readonly="1"
                                           decoration-danger="seances_restantes == 0"
                                           decoration-warning="seances_restantes &gt; 0 and seances_restantes &lt;= 3"/>
                                    <field name="montant" sum="Montant total"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Facturation tiers payant">
                            <group>
                                <field name="taux_remboursement"/>
                                <field name="montant_total" readonly="1"/>
                                <field name="montant_tiers_payant" readonly="1"/>
                                <field name="montant_patient" readonly="1"/>
                            </group>
                        </page>
                        <page string="Bordereau">
                            <group>
                                <field name="bordereau_id" readonly="1"/>
                                <field name="date_debut_soins" readonly="1"/>
                                <field name="date_fin_soins" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_feuille_soins_list" model="ir.ui.view">
        <field name="name">cps.feuille.soins.list</field>
        <field name="model">cps.feuille.soins</field>
        <field name="arch" type="xml">
            <tree string="Feuilles de soins"  default_order="date_debut_soins desc" decoration-muted="state=='cancelled'"
                  decoration-success="state=='paid'" decoration-info="state=='submitted'">
                <field name="name"/>
                <field name="fsa_numero" optional="show"/>
                <field name="patient_id"/>
                <field name="patient_dn" string="DN"/>
                <field name="praticien_id"/>
                <field name="date_prescription"/>
                <field name="date_debut_soins"/>
                <field name="date_fin_soins"/>
                <field name="montant_total" sum="Total"/>
                <field name="montant_tiers_payant" sum="Total CPS"/>
                <field name="montant_patient" sum="Total Patient"/>
                <field name="bordereau_id" optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state=='paid'" decoration-info="state=='submitted'"
                       decoration-warning="state=='confirmed'" decoration-muted="state=='cancelled'"/>
            </tree>
        </field>
    </record>

  <!-- ══════════════════════════════════════════════════════════════════════
       BARRE DE RECHERCHE – FIX filtre "Mes feuilles"
  ══════════════════════════════════════════════════════════════════════ -->
  <record id="view_feuille_soins_search" model="ir.ui.view">
    <field name="name">cps.feuille.soins.search</field>
    <field name="model">cps.feuille.soins</field>
    <field name="arch" type="xml">
      <search string="Rechercher une feuille de soins">
        <field name="name"        string="Référence"/>
        <field name="patient_id"  string="Patient"/>
        <field name="praticien_id" string="Praticien"/>
        <field name="date_debut_soins"  string="Date"/>
        <filter name="mes_feuilles"
                string="Mes feuilles"
                domain="[('praticien_id.user_ids', 'in', [uid])]"/>

        <separator/>
        <filter name="brouillon"    string="Brouillon"   domain="[('state', '=', 'draft')]"/>
        <filter name="validee"      string="Validées"    domain="[('state', '=', 'done')]"/>
        <filter name="transmise"    string="Transmises"  domain="[('state', '=', 'transmitted')]"/>
        <filter name="non_bordereau" string="Sans bordereau"
                domain="[('bordereau_id', '=', False)]"/>

        <separator/>
        <filter name="ce_mois" string="Ce mois"
                domain="[('date_debut_soins', '&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d')),
                         ('date_debut_soins', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d'))]"/>

        <group expand="0" string="Grouper par">
          <filter name="group_patient"   string="Patient"   context="{'group_by': 'patient_id'}"/>
          <filter name="group_praticien" string="Praticien" context="{'group_by': 'praticien_id'}"/>
          <filter name="group_mois"      string="Mois"      context="{'group_by': 'date_debut_soins:month'}"/>
          <filter name="group_state"     string="État"      context="{'group_by': 'state'}"/>
        </group>
      </search>
    </field>
  </record>

    <record id="action_feuille_soins" model="ir.actions.act_window">
        <field name="name">Feuilles de soins</field>
        <field name="res_model">cps.feuille.soins</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_feuille_soins_search"/>
        <field name="context">{'search_default_mes_feuilles': 1, 'search_default_no_bordereau': 1}</field>
    </record>
</odoo>
