<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── FORM ── -->
    <record id="view_feuille_soins_form" model="ir.ui.view">
        <field name="name">cps.feuille.soins.form</field>
        <field name="model">cps.feuille.soins</field>
        <field name="arch" type="xml">
            <form string="Feuille de soins">
                <header>
                    <button name="action_confirm" string="Confirmer" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_submit" string="Soumettre à la CPS" type="object"
                            class="btn-primary" invisible="state != 'confirmed'"/>
                    <button name="action_paid" string="Marquer remboursée" type="object"
                            invisible="state != 'submitted'"/>
                    <button name="action_cancel" string="Annuler" type="object"
                            invisible="state in ('cancelled', 'paid')"/>
                    <button name="action_reset_draft" string="Remettre en brouillon" type="object"
                            invisible="state != 'cancelled'"/>
                    <button name="action_print_feuille" string="Imprimer" type="object"
                            icon="fa-print"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,submitted,paid"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="N° Facture"/>
                        <h1><field name="name"/></h1>
                        <label for="fsa_numero" string="N° FSA25"/>
                        <h3><field name="fsa_numero" placeholder="ex: 038998"/></h3>
                    </div>
                    <field name="photo_feuille" widget="image" class="oe_avatar"
                           options="{'preview_image': 'photo_feuille'}"/>
                    <group>
                        <group string="Bénéficiaire des soins">
                            <field name="patient_id" options="{'quick_create': True}"/>
                            <field name="patient_dn" readonly="1"/>
                        </group>
                        <group string="Auxiliaire médical">
                            <field name="praticien_id"/>
                            <field name="code_auxiliaire" readonly="1"/>
                            <field name="auxiliaire_remplacant"/>
                            <field name="accord_prealable"/>
                        </group>
                    </group>
                    <group>
                        <group string="Prescription">
                            <field name="parcours_soins"/>
                            <field name="code_prescripteur"/>
                            <field name="date_prescription"/>
                        </group>
                        <group string="Condition de prise en charge">
                            <field name="condition"/>
                            <field name="num_rsr"/>
                            <field name="num_panier"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Prestations des actes">
                            <field name="acte_ids">
                                <tree editable="bottom">
                                    <field name="date_acte"/>
                                    <field name="lettre_cle"/>
                                    <field name="coefficient"/>
                                    <field name="ifd"/>
                                    <field name="ik"/>
                                    <field name="dimanche_ferie"/>
                                    <field name="nuit"/>
                                    <field name="montant" sum="Total actes"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Facturation tiers payant">
                            <group>
                                <field name="taux_remboursement"/>
                                <field name="montant_total" readonly="1"/>
                                <field name="montant_tiers_payant" readonly="1"
                                       string="Montant CPS (tiers payant)"/>
                                <field name="montant_patient" readonly="1"
                                       string="Montant payé par l'assuré"/>
                            </group>
                        </page>
                        <page string="Bordereau">
                            <group>
                                <field name="bordereau_id" readonly="1"/>
                                <field name="date_debut_soins" readonly="1"/>
                                <field name="date_fin_soins" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── TREE ── colonnes avec sum = ligne de totalisation automatique -->
    <record id="view_feuille_soins_list" model="ir.ui.view">
        <field name="name">cps.feuille.soins.list</field>
        <field name="model">cps.feuille.soins</field>
        <field name="arch" type="xml">
            <tree string="Feuilles de soins"
                  decoration-muted="state=='cancelled'"
                  decoration-success="state=='paid'"
                  decoration-info="state=='submitted'">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="patient_dn"/>
                <field name="praticien_id" optional="hide"/>
                <field name="date_prescription"/>
                <field name="date_debut_soins"/>
                <field name="date_fin_soins"/>
                <field name="montant_total"        sum="Total général"/>
                <field name="montant_tiers_payant" sum="Total CPS"/>
                <field name="montant_patient"      sum="Total Patient"/>
                <field name="bordereau_id" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-success="state=='paid'"
                       decoration-info="state=='submitted'"
                       decoration-warning="state=='confirmed'"
                       decoration-muted="state=='cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- ── SEARCH ── filtres sur champs stockés annee_prescription / mois_prescription -->
    <record id="view_feuille_soins_search" model="ir.ui.view">
        <field name="name">cps.feuille.soins.search</field>
        <field name="model">cps.feuille.soins</field>
        <field name="arch" type="xml">
            <search string="Rechercher une feuille de soins">
                <field name="name"/>
                <field name="patient_id"/>
                <field name="praticien_id"/>
                <field name="bordereau_id"/>

                <!-- État -->
                <filter name="draft"     string="Brouillon"    domain="[('state','=','draft')]"/>
                <filter name="confirmed" string="Confirmées"   domain="[('state','=','confirmed')]"/>
                <filter name="submitted" string="Soumises CPS" domain="[('state','=','submitted')]"/>
                <filter name="paid"      string="Remboursées"  domain="[('state','=','paid')]"/>
                <separator/>

                <!-- Période — filtres fiables via champs stockés -->
                <filter name="mois_en_cours" string="Mois en cours"
                        domain="[('annee_prescription','=', context_today().year),
                                 ('mois_prescription', '=', context_today().month)]"/>
                <filter name="mois_precedent" string="Mois précédent"
                        domain="[('annee_prescription','=', (context_today().year if context_today().month &gt; 1 else context_today().year - 1)),
                                 ('mois_prescription', '=', (context_today().month - 1 if context_today().month &gt; 1 else 12))]"/>
                <filter name="annee_en_cours" string="Année en cours"
                        domain="[('annee_prescription','=', context_today().year)]"/>
                <filter name="annee_precedente" string="Année précédente"
                        domain="[('annee_prescription','=', context_today().year - 1)]"/>
                <separator/>
                <filter name="no_bordereau" string="Sans bordereau"
                        domain="[('bordereau_id','=',False)]"/>

                <group expand="0" string="Grouper par">
                    <filter name="group_praticien" string="Praticien"
                            context="{'group_by': 'praticien_id'}"/>
                    <filter name="group_state"     string="État"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_bordereau" string="Bordereau"
                            context="{'group_by': 'bordereau_id'}"/>
                    <filter name="group_mois"      string="Mois"
                            context="{'group_by': 'date_prescription:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── ACTION — défaut : mois en cours ── -->
    <record id="action_feuille_soins" model="ir.actions.act_window">
        <field name="name">Feuilles de soins</field>
        <field name="res_model">cps.feuille.soins</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_feuille_soins_search"/>
        <field name="context">{'search_default_mois_en_cours': 1}</field>
    </record>

</odoo>
