<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════════════════════════════
         VUE FORMULAIRE – Feuille de soins
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_feuille_soins_form" model="ir.ui.view">
        <field name="name">cps.feuille.soins.form</field>
        <field name="model">cps.feuille.soins</field>
        <field name="arch" type="xml">
            <form string="Feuille de soins">
                <header>
                    <button name="action_confirm" string="Confirmer" type="object"
                            icon="fa-check" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_paid" string="Remboursée" type="object"
                            icon="fa-euro" invisible="state != 'submitted'"/>
                    <button name="action_reset_draft" string="Remettre en brouillon"
                            type="object" icon="fa-undo"
                            invisible="state != 'cancelled'"/>
                    <button name="action_print_facture_mutuelle"
                            string="Facture mutuelle" type="object"
                            icon="fa-file-text-o"
                            invisible="not has_mutuelle"/>
                    <button name="os_pdf_report_generator.pf_fsa25_feuille_soins_sans_fond"
                            string="Imprimer sur formulaire"
                            invisible="state != 'confirmed'"
                            class="btn-primary"
                            type="action"
                            icon="fa-print"/>
                    <button name="os_pdf_report_generator.pf_fsa25_feuille_soins_avec_fond"
                            string="Imprimer sur page vierge"
                            invisible="state != 'confirmed'"
                            type="action"
                            icon="fa-print"/>
                    <button name="action_cancel" string="Annuler" type="object"
                            icon="fa-ban"
                            invisible="state in ('cancelled', 'paid')"/>
                    <button name="action_submit" string="Soumettre à la CPS" type="object"
                            icon="fa-paper-plane"
                            invisible="state != 'confirmed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,submitted,paid"/>
                </header>
                <sheet>

                    <!-- ── Alerte séances futures ──────────────────── -->
                    <div class="alert alert-warning mb8"
                         invisible="not has_future_seances or state != 'draft'">
                        <i class="fa fa-clock-o me-2"/>
                        <strong>Séances planifiées dans le futur.</strong>
                        Cette feuille ne pourra être confirmée qu'une fois toutes les séances
                        passées ou marquées <em>Effectuée / Annulée / Non présentation</em>.
                    </div>

                    <div class="oe_title">
                        <label for="name" string="N° Facture"/>
                        <h1><field name="name" readonly="1"/></h1>
                        <label for="fsa_numero" string="N° FSA25"/>
                        <h3><field name="fsa_numero" readonly="1"/></h3>
                    </div>
                    <field name="photo_feuille" widget="image" class="oe_avatar"
                           options="{'preview_image': 'photo_feuille'}"/>

                    <!-- Ordonnance : exclut celles dont toutes les séances sont planifiées/réalisées -->
                    <group string="1 – Ordonnance (import automatique)">
                        <field name="ordonnance_id"
                               domain="[('state', 'in', ['en_cours', 'brouillon']), ('has_seances_disponibles', '=', True)]"
                               options="{'no_create': False}"
                               help="Sélectionnez l'ordonnance EN PREMIER : patient, praticien et prescription sont importés automatiquement. Seules les ordonnances ayant encore des séances disponibles sont proposées."/>
                    </group>

                    <group>
                        <group string="2 – Bénéficiaire des soins">
                            <field name="patient_id"
                                   domain="[('category_id.name', '=', 'Patient CPS')]"
                                   options="{'quick_create': False}"
                                   readonly="ordonnance_id != False"/>
                            <field name="patient_dn" readonly="1" string="DN"/>
                            <field name="has_mutuelle" widget="boolean_toggle"
                                   string="Mutuelle" readonly="1"/>
                        </group>
                        <group string="3 – Auxiliaire médical">
                            <field name="auxiliaire_remplacant"/>
                            <field name="praticien_id"
                                   domain="[('category_id.name', '=', 'Praticien CPS')]"
                                   readonly="not auxiliaire_remplacant"
                                   required="1"
                                   options="{'no_create': False}"/>
                            <field name="praticien_profession" invisible="1"/>
                            <field name="code_auxiliaire" readonly="1" string="Code auxiliaire"/>
                            <field name="accord_prealable" invisible="not auxiliaire_remplacant"/>
                            <field name="company_id" readonly="state != 'draft'"/>
                        </group>
                    </group>

                    <group string="Modèle de saisie rapide" invisible="state != 'draft'">
                        <field name="modele_id"
                               domain="[('profession', '=', praticien_profession)]"
                               options="{'no_create': False}"/>
                    </group>

                    <group>
                        <group string="Prescription">
                            <!-- parcours_soins coché automatiquement si ordonnance sélectionnée -->
                            <field name="parcours_soins" widget="boolean_toggle"/>
                            <field name="code_prescripteur"/>
                            <field name="date_prescription"/>
                            <field name="date_feuille"
                                   help="Date du formulaire FSA25 : au maximum entre la date du jour et la date de la dernière séance."/>
                        </group>
                        <group string="Condition de prise en charge">
                            <field name="condition"/>
                            <field name="motif_derogation"
                                   invisible="condition != 'autre'"
                                   required="condition == 'autre'"
                                   placeholder="Précisez le motif…"/>
                            <field name="num_rsr"/>
                            <field name="num_panier"/>
                        </group>
                    </group>

                    <field name="has_future_seances" invisible="1"/>
                    <field name="has_mutuelle" invisible="1"/>

                    <notebook>
                        <page string="Prestations des actes" name="actes">
                            <div class="mb8" invisible="state != 'draft'">
                                <button name="action_open_date_wizard"
                                        string="Ajouter des séances par sélection de dates"
                                        icon="fa-calendar-plus-o"
                                        type="object" class="btn btn-secondary"/>
                            </div>
                            <field name="acte_ids">
                                <tree editable="bottom"
                                      decoration-muted="state_seance == 'annulee'"
                                      decoration-warning="state_seance == 'non_presentation'"
                                      decoration-success="state_seance == 'effectuee'"
                                      decoration-info="state_seance == 'planifiee'">
                                    <field name="acte_type_id"
                                           domain="[('profession', 'in', [False, parent.praticien_profession])]"
                                           optional="show" string="Acte (catalogue)"
                                           options="{'no_create': False}"/>
                                    <field name="date_acte"/>
                                    <field name="heure_acte" widget="float_time" string="Heure"
                                           optional="show"/>
                                    <field name="state_seance"
                                           widget="badge"
                                           decoration-success="state_seance == 'effectuee'"
                                           decoration-info="state_seance == 'planifiee'"
                                           decoration-warning="state_seance == 'non_presentation'"
                                           decoration-muted="state_seance == 'annulee'"/>
                                    <field name="lettre_cle"/>
                                    <field name="coefficient"/>
                                    <field name="ifd"/>
                                    <field name="ik"/>
                                    <field name="dimanche_ferie"/>
                                    <field name="nuit"/>
                                    <field name="ordonnance_ligne_id" optional="show" string="Ligne ord."/>
                                    <!-- Restantes officiel (sans planifiées) -->
                                    <field name="seances_restantes" optional="show" readonly="1"
                                           string="Rest."
                                           decoration-danger="seances_restantes == 0"
                                           decoration-warning="seances_restantes &gt; 0 and seances_restantes &lt;= 3"/>
                                    <!-- Restantes théoriques (planifiées comptées) -->
                                    <field name="seances_theorique_restantes" optional="show" readonly="1"
                                           string="Rest. (théor.)"
                                           decoration-danger="seances_theorique_restantes == 0"
                                           decoration-warning="seances_theorique_restantes &gt; 0 and seances_theorique_restantes &lt;= 3"/>
                                    <field name="montant" sum="Montant total"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Facturation tiers payant" name="facturation">
                            <group>
                                <field name="taux_remboursement"/>
                                <field name="montant_total"        readonly="1"/>
                                <field name="montant_tiers_payant" readonly="1"/>
                                <field name="montant_patient"      readonly="1"/>
                            </group>
                        </page>
                        <page string="Bordereau" name="bordereau">
                            <group>
                                <field name="bordereau_id"     readonly="1"/>
                                <field name="date_debut_soins" readonly="1"/>
                                <field name="date_fin_soins"   readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════
         VUE LISTE – Feuilles de soins
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_feuille_soins_list" model="ir.ui.view">
        <field name="name">cps.feuille.soins.list</field>
        <field name="model">cps.feuille.soins</field>
        <field name="arch" type="xml">
            <tree string="Feuilles de soins" default_order="date_debut_soins desc"
                  decoration-muted="state=='cancelled'"
                  decoration-success="state=='paid'"
                  decoration-info="state=='submitted'"
                  decoration-warning="has_future_seances and state == 'draft'">
                <field name="name"/>
                <field name="fsa_numero"          optional="show"/>
                <field name="patient_id"/>
                <field name="patient_dn"          string="DN"/>
                <field name="praticien_id"/>
                <field name="date_prescription"/>
                <field name="date_feuille"        string="Date feuille" optional="show"/>
                <field name="date_debut_soins"/>
                <field name="date_fin_soins"/>
                <field name="has_future_seances"  string="Séances futures" optional="show"
                       widget="boolean"/>
                <field name="montant_total"        sum="Total"/>
                <field name="montant_tiers_payant" sum="Total CPS"/>
                <field name="montant_patient"      sum="Total Patient"/>
                <field name="bordereau_id"         optional="show"/>
                <field name="state" widget="badge"
                       decoration-success="state=='paid'"
                       decoration-info="state=='submitted'"
                       decoration-warning="state=='confirmed'"
                       decoration-muted="state=='cancelled'"/>
            </tree>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════
         VUE RECHERCHE – Feuilles de soins
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_feuille_soins_search" model="ir.ui.view">
        <field name="name">cps.feuille.soins.search</field>
        <field name="model">cps.feuille.soins</field>
        <field name="arch" type="xml">
            <search string="Rechercher une feuille de soins">
                <field name="name"            string="Référence"/>
                <field name="patient_id"      string="Patient"/>
                <field name="praticien_id"    string="Praticien"/>
                <field name="date_debut_soins" string="Date"/>
                <filter name="mes_feuilles"
                        string="Mes feuilles"
                        domain="[('praticien_id.user_ids', 'in', [uid])]"/>
                <separator/>
                <filter name="brouillon"     string="Brouillon"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="avec_seances_futures"
                        string="Séances futures (brouillon bloqué)"
                        domain="[('has_future_seances', '=', True), ('state', '=', 'draft')]"/>
                <filter name="confirmee"     string="Confirmées"
                        domain="[('state', '=', 'confirmed')]"/>
                <filter name="transmise"     string="Transmises"
                        domain="[('state', '=', 'submitted')]"/>
                <filter name="non_bordereau" string="Sans bordereau"
                        domain="[('bordereau_id', '=', False)]"/>
                <separator/>
                <filter name="ce_mois" string="Ce mois"
                        domain="[
                            ('date_debut_soins', '&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d')),
                            ('date_debut_soins', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d'))
                        ]"/>
                <group expand="0" string="Grouper par">
                    <filter name="group_patient"   string="Patient"
                            context="{'group_by': 'patient_id'}"/>
                    <filter name="group_praticien" string="Praticien"
                            context="{'group_by': 'praticien_id'}"/>
                    <filter name="group_mois"      string="Mois"
                            context="{'group_by': 'date_debut_soins:month'}"/>
                    <filter name="group_state"     string="État"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════
         VUE FORMULAIRE – sur cps.feuille.soins.acte
    ══════════════════════════════════════════════════════════════════════ -->

    <record id="view_feuille_soins_acte_form" model="ir.ui.view">
        <field name="name">cps.feuille.soins.acte.form</field>
        <field name="model">cps.feuille.soins.acte</field>
        <field name="arch" type="xml">
            <form string="Séance">
                <header>
                    <field name="state_seance" widget="statusbar"
                           statusbar_visible="planifiee,effectuee"
                           statusbar_clickable="1"/>
                </header>
                <sheet>

                    <!-- ── Bandeau patient / feuille ──────────────────────── -->
                    <div class="oe_button_box" name="button_box">
                        <button type="object"
                                name="action_open_feuille"
                                class="oe_stat_button"
                                icon="fa-file-medical"
                                invisible="not feuille_id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Feuille</span>
                                <span class="o_stat_value">
                                    <field name="feuille_name" readonly="1"/>
                                </span>
                            </div>
                        </button>
                        <button type="object"
                                name="action_open_feuille"
                                class="oe_stat_button"
                                icon="fa-euro"
                                invisible="not feuille_id">
                            <div class="o_field_widget o_stat_info">
                                <span class="o_stat_text">Part CPS</span>
                                <span class="o_stat_value">
                                    <field name="montant_cps" readonly="1"/> F
                                </span>
                            </div>
                        </button>
                    </div>

                    <!-- ── Titre dynamique ──────────────────────────────────── -->
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"
                                   placeholder="Séance non nommée"/>
                        </h1>
                    </div>

                    <!-- ── Bloc patient (lecture seule, provient de la feuille) ── -->
                    <div class="alert alert-info mb16 d-flex align-items-center gap-3"
                         style="border-left: 4px solid #1F6B3A;"
                         invisible="not patient_id">
                        <i class="fa fa-user-circle fa-2x" style="color:#1F6B3A;"/>
                        <div>
                            <strong>
                                <field name="patient_nom"    readonly="1" nolabel="1"
                                       class="d-inline text-uppercase"/>
                                &#160;
                                <field name="patient_prenom" readonly="1" nolabel="1"
                                       class="d-inline"/>
                            </strong>
                            <span class="text-muted ms-2">
                                DN&#160;<field name="patient_dn" readonly="1"
                                               nolabel="1" class="d-inline"/>
                            </span>
                        </div>
                    </div>

                    <group>
                        <!-- Colonne gauche : planification -->
                        <group string="Planification">
                            <field name="date_acte"/>
                            <field name="heure_acte"    widget="float_time"
                                   string="Heure de début"/>
                            <field name="state_seance"  widget="radio"/>
                            <field name="praticien_id"  readonly="1"
                                   string="Praticien"/>
                        </group>

                        <!-- Colonne droite : acte et tarification -->
                        <group string="Acte &amp; tarification">
                            <field name="acte_type_id"
                                   options="{'no_create': False}"
                                   string="Type d'acte"/>
                            <field name="lettre_cle"/>
                            <field name="coefficient"   digits="[6,2]"/>
                            <field name="montant"       string="Montant (F XPF)"/>
                        </group>
                    </group>

                    <group string="Frais et majorations">
                        <group>
                            <field name="ifd"           string="IFD (unités)"/>
                            <field name="ik"            string="IK (unités)"/>
                            <field name="taux_majoration" string="Taux majoration (%)"/>
                        </group>
                        <group>
                            <field name="dimanche_ferie" widget="boolean_toggle"
                                   string="Dimanche / Jour férié"/>
                            <field name="nuit"           widget="boolean_toggle"
                                   string="Nuit"/>
                        </group>
                    </group>

                    <!-- ── Lien ordonnance ──────────────────────────────────── -->
                    <group string="Ordonnance associée"
                           invisible="not ordonnance_ligne_id">
                        <field name="ordonnance_ligne_id" readonly="1"
                               string="Ligne d'ordonnance"/>
                        <field name="seances_restantes"   readonly="1"
                               string="Restantes (officiel)"
                               decoration-danger="seances_restantes == 0"
                               decoration-warning="seances_restantes &gt; 0 and seances_restantes &lt;= 3"/>
                        <field name="seances_theorique_restantes" readonly="1"
                               string="Restantes (théoriques)"
                               decoration-danger="seances_theorique_restantes == 0"
                               decoration-warning="seances_theorique_restantes &gt; 0 and seances_theorique_restantes &lt;= 3"/>
                    </group>

                    <!-- ── Champs techniques cachés ─────────────────────────── -->
                    <field name="feuille_id"            invisible="1"/>
                    <field name="patient_id"            invisible="1"/>
                    <field name="feuille_name"          invisible="1"/>
                    <field name="montant_cps"           invisible="1"/>
                    <field name="montant_patient_feuille" invisible="1"/>
                    <field name="feuille_state"         invisible="1"/>
                    <field name="datetime_acte"         invisible="1"/>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════
         VUE CALENDRIER – sur cps.feuille.soins.acte
    ══════════════════════════════════════════════════════════════════════ -->
<!--    quick_create_view_id="%(os_auxiliaire_medical.view_feuille_soins_acte_quick_create)d"-->
<!--    form_view_id="%(os_auxiliaire_medical.view_feuille_soins_acte_form)d"-->

    <record id="view_acte_calendar" model="ir.ui.view">
        <field name="name">cps.feuille.soins.acte.calendar</field>
        <field name="model">cps.feuille.soins.acte</field>
        <field name="arch" type="xml">
            <calendar string="Agenda des séances"
                      date_start="datetime_acte"
                      date_delay="date_delay"
                      color="patient_id"
                      mode="week"
                      event_open_popup="1"
                      quick_create="1"
                      quick_create_view_id="%(os_auxiliaire_medical.view_feuille_soins_acte_form)d"
            >
                <field name="patient_id"   string="Patient" filters="1" avatar_field="avatar_128"/>
                <field name="praticien_id" string="Praticien" filters="1"/>
                <field name="state_seance" string="Statut" filters="1"/>
                <field name="lettre_cle"   string="Acte"/>
                <field name="coefficient"  string="Coefficient" filters="1"/>
                <field name="montant"      string="Montant"/>
            </calendar>
        </field>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════
         VUE RECHERCHE – Actes
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="view_acte_search" model="ir.ui.view">
        <field name="name">cps.feuille.soins.acte.search</field>
        <field name="model">cps.feuille.soins.acte</field>
        <field name="arch" type="xml">
            <search string="Rechercher une séance">
                <field name="patient_id"   string="Patient"/>
                <field name="praticien_id" string="Praticien"/>
                <field name="date_acte"    string="Date"/>
                <field name="lettre_cle"   string="Lettre clé"/>
                <filter name="planifiees"       string="Planifiées"
                        domain="[('state_seance', '=', 'planifiee')]"/>
                <filter name="effectuees"       string="Effectuées"
                        domain="[('state_seance', '=', 'effectuee')]"/>
                <filter name="non_presentation" string="Non présentation"
                        domain="[('state_seance', '=', 'non_presentation')]"/>
                <filter name="annulees"         string="Annulées"
                        domain="[('state_seance', '=', 'annulee')]"/>
                <separator/>
                <filter name="cette_semaine" string="Cette semaine"
                        domain="[
                            ('date_acte', '&gt;=', (context_today() + relativedelta(weekday=0, weeks=-1)).strftime('%Y-%m-%d')),
                            ('date_acte', '&lt;=', (context_today() + relativedelta(weekday=6)).strftime('%Y-%m-%d'))
                        ]"/>
                <filter name="ce_mois" string="Ce mois"
                        domain="[
                            ('date_acte', '&gt;=', (context_today() + relativedelta(day=1)).strftime('%Y-%m-%d')),
                            ('date_acte', '&lt;=', (context_today() + relativedelta(day=31)).strftime('%Y-%m-%d'))
                        ]"/>
                <separator/>
                <filter name="mes_seances" string="Mes séances"
                        domain="[('praticien_id.user_ids', 'in', [uid])]"/>
                <group expand="0" string="Grouper par">
                    <filter name="g_patient"   string="Patient"
                            context="{'group_by': 'patient_id'}"/>
                    <filter name="g_praticien" string="Praticien"
                            context="{'group_by': 'praticien_id'}"/>
                    <filter name="g_statut"    string="Statut"
                            context="{'group_by': 'state_seance'}"/>
                    <filter name="g_semaine"   string="Semaine"
                            context="{'group_by': 'date_acte:week'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ── Action fenêtre (utile pour les liens smart buttons) ── -->

    <record id="action_feuille_soins_acte_form" model="ir.actions.act_window">
        <field name="name">Séances</field>
        <field name="res_model">cps.feuille.soins.acte</field>
        <field name="view_mode">list,form,calendar</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'form',
                    'view_id': ref('view_feuille_soins_acte_form')})]"/>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════
         ACTION – Agenda des séances
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="action_feuille_soins_calendar" model="ir.actions.act_window">
        <field name="name">Agenda des séances</field>
        <field name="res_model">cps.feuille.soins.acte</field>
        <field name="view_mode">calendar,tree,form</field>
        <field name="search_view_id" ref="view_acte_search"/>
        <field name="context">{'search_default_cette_semaine': 1,
                               'search_default_planifiees': 1}</field>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'calendar', 'view_id': ref('view_acte_calendar')})]"/>
    </record>

    <!-- ══════════════════════════════════════════════════════════════════
         ACTION – Feuilles de soins
    ══════════════════════════════════════════════════════════════════════ -->
    <record id="action_feuille_soins" model="ir.actions.act_window">
        <field name="name">Feuilles de soins</field>
        <field name="res_model">cps.feuille.soins</field>
        <field name="view_mode">tree,form</field>
        <field name="search_view_id" ref="view_feuille_soins_search"/>
        <field name="context">{'search_default_mes_feuilles': 1}</field>
    </record>

</odoo>
