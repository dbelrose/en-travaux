<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_tarif_historique_form" model="ir.ui.view">
        <field name="name">cps.tarif.historique.form</field>
        <field name="model">cps.tarif.historique</field>
        <field name="arch" type="xml">
            <form string="Historique des tarifs">
                <header>
                    <button name="action_appliquer_tarif"
                            string="Appliquer ce tarif"
                            type="object"
                            class="btn-primary"
                            icon="fa-check"
                            confirm="Cette action met à jour le tarif_unitaire de TOUS les actes de cette lettre clé et les paramètres de configuration. Continuer ?"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Tarif">
                            <field name="lettre_cle"/>
                            <field name="tarif_unitaire"/>
                            <field name="date_application"/>
                            <field name="reference"/>
                        </group>
                        <group string="Suppléments (optionnels)">
                            <field name="supplement_ifd"
                                   help="Laisser 0 pour ne pas modifier le supplément IFD en configuration"/>
                            <field name="supplement_ifn"
                                   help="Laisser 0 pour ne pas modifier le supplément IFN en configuration"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                    </group>
                    <field name="notes" placeholder="Notes ou contexte de cette révision tarifaire…"/>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_tarif_historique_list" model="ir.ui.view">
        <field name="name">cps.tarif.historique.list</field>
        <field name="model">cps.tarif.historique</field>
        <field name="arch" type="xml">
            <tree string="Historique des tarifs" default_order="date_application desc">
                <field name="date_application"/>
                <field name="lettre_cle"/>
                <field name="tarif_unitaire"/>
                <field name="supplement_ifd"/>
                <field name="supplement_ifn"/>
                <field name="reference"/>
                <button name="action_appliquer_tarif" type="object"
                        string="Appliquer" icon="fa-check"
                        confirm="Mettre à jour tous les actes de cette lettre clé ?"/>
            </tree>
        </field>
    </record>

    <record id="action_tarif_historique" model="ir.actions.act_window">
        <field name="name">Historique des tarifs</field>
        <field name="res_model">cps.tarif.historique</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
