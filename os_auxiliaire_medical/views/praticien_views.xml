<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_praticien_form" model="ir.ui.view">
        <field name="name">cps.praticien.form</field>
        <field name="model">cps.praticien</field>
        <field name="arch" type="xml">
            <form string="Auxiliaire médical">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_feuilles" type="object" class="oe_stat_button"
                                icon="fa-file-text-o">
                            <field name="feuille_count" widget="statinfo" string="Feuilles"/>
                        </button>
                        <button name="action_view_bordereaux" type="object" class="oe_stat_button"
                                icon="fa-list">
                            <field name="bordereau_count" widget="statinfo" string="Bordereaux"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Identification CPS">
                            <field name="code_auxiliaire"/>
                            <field name="profession"/>
                        </group>
                        <group string="Coordonnées">
                            <field name="tel"/>
                            <field name="bp"/>
                            <field name="email"/>
                        </group>
                    </group>
                    <group string="Compte Odoo associé">
                        <field name="user_id"
                               help="Associez un utilisateur pour que ses feuilles de soins lui soient pré-attribuées automatiquement."/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_praticien_list" model="ir.ui.view">
        <field name="name">cps.praticien.list</field>
        <field name="model">cps.praticien</field>
        <field name="arch" type="xml">
            <tree string="Praticiens">
                <field name="name"/>
                <field name="code_auxiliaire"/>
                <field name="profession"/>
                <field name="tel"/>
                <field name="user_id"/>
                <field name="feuille_count"/>
                <field name="company_id" groups="base.group_multi_company" optional="show"/>
            </tree>
        </field>
    </record>

    <record id="action_praticien" model="ir.actions.act_window">
        <field name="name">Praticiens</field>
        <field name="res_model">cps.praticien</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
