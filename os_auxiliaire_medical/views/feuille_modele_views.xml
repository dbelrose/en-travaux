<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_feuille_modele_form" model="ir.ui.view">
        <field name="name">cps.feuille.soins.modele.form</field>
        <field name="model">cps.feuille.soins.modele</field>
        <field name="arch" type="xml">
            <form string="Modèle de feuille de soins">
                <sheet>
                    <div class="oe_title">
                        <label for="name" string="Nom du modèle"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Paramètres généraux">
                            <field name="profession"/>
                            <field name="condition"/>
                            <field name="taux_remboursement"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                        </group>
                        <group string="Statistiques">
                            <field name="nb_lignes" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Actes du modèle">
                            <field name="ligne_ids">
                                <tree editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="acte_type_id"
                                           domain="[('profession', 'in', [False, parent.profession])]"/>
                                    <field name="lettre_cle" readonly="1"/>
                                    <field name="coefficient"/>
                                    <field name="ifd"/>
                                    <field name="ik"/>
                                    <field name="dimanche_ferie"/>
                                    <field name="nuit"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_feuille_modele_list" model="ir.ui.view">
        <field name="name">cps.feuille.soins.modele.list</field>
        <field name="model">cps.feuille.soins.modele</field>
        <field name="arch" type="xml">
            <tree string="Modèles de feuilles">
                <field name="profession"/>
                <field name="name"/>
                <field name="condition"/>
                <field name="taux_remboursement"/>
                <field name="nb_lignes"/>
            </tree>
        </field>
    </record>

    <record id="view_feuille_modele_search" model="ir.ui.view">
        <field name="name">cps.feuille.soins.modele.search</field>
        <field name="model">cps.feuille.soins.modele</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="profession"/>
                <group expand="0" string="Grouper par">
                    <filter name="group_profession" string="Profession" context="{'group_by': 'profession'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_feuille_modele" model="ir.actions.act_window">
        <field name="name">Modèles de feuilles</field>
        <field name="res_model">cps.feuille.soins.modele</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_feuille_modele_search"/>
    </record>
</odoo>
