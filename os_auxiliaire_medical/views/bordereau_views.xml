<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Formulaire ─────────────────────────────────────────────────────── -->
    <record id="view_bordereau_form" model="ir.ui.view">
        <field name="name">cps.bordereau.form</field>
        <field name="model">cps.bordereau</field>
        <field name="arch" type="xml">
            <form string="Bordereau de facturation">
                <header>
                    <button name="action_validate" string="Valider" type="object"
                            class="btn-primary" invisible="state != 'draft'"/>
                    <button name="action_submit_cps" string="Transmettre à la CPS"
                            type="object" class="btn-primary"
                            invisible="state != 'validated'"/>
                    <button name="action_close" string="Clôturer" type="object"
                            invisible="state != 'submitted'"/>
                    <button name="action_reset_draft" string="Remettre en brouillon"
                            type="object" invisible="state == 'draft'"/>
                    <button name="action_print_bordereau" string="Imprimer PDF"
                            type="object" icon="fa-file-pdf-o"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,validated,submitted,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_feuilles" type="object"
                                class="oe_stat_button" icon="fa-file-medical">
                            <field name="nb_feuilles" widget="statinfo" string="Feuilles"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Identification">
                            <field name="praticien_id"/>
                            <field name="mois"/>
                            <field name="date_bordereau"/>
                            <field name="company_id"/>
                        </group>
                        <group string="Totaux">
                            <field name="total_cps"     readonly="1"/>
                            <field name="total_patient" readonly="1"/>
                            <field name="total_general" readonly="1"/>
                        </group>
                    </group>

                    <!-- ── AJOUT : sélection du modèle de document ── -->
                    <group string="Document">
                        <field name="modele_id"
                               options="{'no_create': False}"
                               placeholder="Modèle par défaut de la société…"/>
                        <field name="modele_entete"  readonly="1" invisible="not modele_id"/>
                        <field name="modele_pied"    readonly="1" invisible="not modele_id"/>
                        <field name="modele_couleur" readonly="1" invisible="not modele_id"/>
                    </group>

                    <notebook>
                        <page string="Feuilles de soins">
                            <field name="feuille_ids" readonly="state != 'draft'">
                                <tree>
                                    <field name="name"/>
                                    <field name="patient_id"/>
                                    <field name="patient_dn"/>
                                    <field name="date_debut_soins"/>
                                    <field name="date_fin_soins"/>
                                    <field name="montant_tiers_payant" sum="Total CPS"/>
                                    <field name="montant_patient"      sum="Total Patient"/>
                                    <field name="montant_total"        sum="Total"/>
                                    <field name="state" widget="badge"/>
                                </tree>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="notes" placeholder="Notes internes..."/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- ── Liste ──────────────────────────────────────────────────────────── -->
    <record id="view_bordereau_list" model="ir.ui.view">
        <field name="name">cps.bordereau.list</field>
        <field name="model">cps.bordereau</field>
        <field name="arch" type="xml">
            <tree string="Bordereaux"
                  decoration-success="state == 'closed'"
                  decoration-info="state == 'submitted'">
                <field name="name"/>
                <field name="praticien_id"/>
                <field name="mois"/>
                <field name="date_bordereau"/>
                <field name="nb_feuilles"/>
                <field name="total_cps"     sum="Total CPS"/>
                <field name="total_patient" sum="Total Patient"/>
                <field name="total_general" sum="Total général"/>
                <field name="modele_id" optional="show" string="Modèle doc."/>
                <field name="state" widget="badge"
                       decoration-success="state == 'closed'"
                       decoration-info="state == 'submitted'"
                       decoration-warning="state == 'validated'"/>
            </tree>
        </field>
    </record>

    <!-- ── Recherche ──────────────────────────────────────────────────────── -->
    <record id="view_bordereau_search" model="ir.ui.view">
        <field name="name">cps.bordereau.search</field>
        <field name="model">cps.bordereau</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="praticien_id"/>
                <field name="mois"/>
                <field name="modele_id" string="Modèle de document"/>
                <filter name="brouillon"  string="Brouillons"
                        domain="[('state', '=', 'draft')]"/>
                <filter name="validated"  string="Validés"
                        domain="[('state', '=', 'validated')]"/>
                <filter name="submitted"  string="Transmis"
                        domain="[('state', '=', 'submitted')]"/>
                <separator/>
                <group expand="0" string="Grouper par">
                    <filter name="g_praticien" string="Praticien"
                            context="{'group_by': 'praticien_id'}"/>
                    <filter name="g_mois"      string="Période"
                            context="{'group_by': 'mois'}"/>
                    <filter name="g_modele"    string="Modèle document"
                            context="{'group_by': 'modele_id'}"/>
                    <filter name="g_state"     string="État"
                            context="{'group_by': 'state'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_bordereau" model="ir.actions.act_window">
        <field name="name">Bordereaux</field>
        <field name="res_model">cps.bordereau</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_bordereau_search"/>
    </record>

</odoo>
