<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form_cps" model="ir.ui.view">
        <field name="name">res.config.settings.cps</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <div class="settings o_searchable_setting" data-string="CPS Feuilles de Soins">
                    <div class="app_settings_block">
                        <h2>CPS – Feuilles de Soins</h2>

                        <div class="row mt16 o_settings_container">

                            <!-- Clé API Anthropic -->
                            <div class="col-12 o_setting_box mb16">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <span class="o_form_label">Clé API Anthropic (OCR Claude Haiku 4.5)</span>
                                    <div class="content-group mt4">
                                        <field name="cps_anthropic_api_key" password="True"
                                               placeholder="sk-ant-…" style="width:100%;max-width:420px;"/>
                                    </div>
                                    <div class="text-muted small mt4">
                                        Pour l'analyse OCR des ordonnances. Obtenir sur
                                        <a href="https://console.anthropic.com" target="_blank">console.anthropic.com</a>.
                                    </div>
                                </div>
                            </div>

                            <!-- Durée de validité ordonnance -->
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <span class="o_form_label">Ordonnances</span>
                                    <div class="content-group mt8">
                                        <div class="row">
                                            <label class="col-sm-7 o_light_label"
                                                   for="cps_ordonnance_validite_jours">
                                                Durée de validité par défaut
                                            </label>
                                            <field name="cps_ordonnance_validite_jours" class="col-sm-3"/>
                                            <span class="col-sm-2 text-muted">j.</span>
                                        </div>
                                        <div class="row mt4">
                                            <label class="col-sm-7 o_light_label"
                                                   for="cps_taux_remboursement_defaut">
                                                Taux remboursement défaut
                                            </label>
                                            <field name="cps_taux_remboursement_defaut" class="col-sm-3"/>
                                            <span class="col-sm-2 text-muted">%</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Tarifs par lettre clé -->
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <span class="o_form_label">Tarifs par lettre clé</span>
                                    <div class="content-group mt8">
                                        <div class="row">
                                            <label class="col-sm-5 o_light_label" for="cps_tarif_amo">AMO / AMK</label>
                                            <field name="cps_tarif_amo" class="col-sm-4"/>
                                            <span class="col-sm-3 text-muted">F XPF</span>
                                        </div>
                                        <div class="row mt4">
                                            <label class="col-sm-5 o_light_label" for="cps_tarif_ami">AMI / AIS / DI</label>
                                            <field name="cps_tarif_ami" class="col-sm-4"/>
                                            <span class="col-sm-3 text-muted">F XPF</span>
                                        </div>
                                        <div class="row mt4">
                                            <label class="col-sm-5 o_light_label" for="cps_tarif_ams">AMS / AMP</label>
                                            <field name="cps_tarif_ams" class="col-sm-4"/>
                                            <span class="col-sm-3 text-muted">F XPF</span>
                                        </div>
                                        <div class="row mt4">
                                            <label class="col-sm-5 o_light_label" for="cps_tarif_amy">AMY</label>
                                            <field name="cps_tarif_amy" class="col-sm-4"/>
                                            <span class="col-sm-3 text-muted">F XPF</span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Suppléments -->
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <span class="o_form_label">Suppléments</span>
                                    <div class="content-group mt8">
                                        <div class="row">
                                            <label class="col-sm-5 o_light_label" for="cps_supplement_ifd">IFD / unité</label>
                                            <field name="cps_supplement_ifd" class="col-sm-4"/>
                                            <span class="col-sm-3 text-muted">F XPF</span>
                                        </div>
                                        <div class="row mt4">
                                            <label class="col-sm-5 o_light_label" for="cps_supplement_ifn">IFN fixe</label>
                                            <field name="cps_supplement_ifn" class="col-sm-4"/>
                                            <span class="col-sm-3 text-muted">F XPF</span>
                                        </div>
                                    </div>
                                    <div class="mt16">
                                        <button name="action_update_all_actes_tarifs" type="object"
                                                string="Appliquer à tous les actes du catalogue"
                                                class="btn btn-secondary" icon="fa-refresh"/>
                                    </div>
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
