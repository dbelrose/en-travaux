<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_patient_form" model="ir.ui.view">
        <field name="name">cps.patient.form</field>
        <field name="model">cps.patient</field>
        <field name="arch" type="xml">
            <form string="Patient">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_feuilles" type="object" class="oe_stat_button"
                                icon="fa-file-medical">
                            <field name="feuille_count" widget="statinfo" string="Feuilles"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="display_name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group string="Identité">
                            <field name="nom"/>
                            <field name="prenom"/>
                            <field name="dn"/>
                            <field name="date_naissance"/>
                        </group>
                        <group string="Contact">
                            <field name="adresse"/>
                            <field name="tel"/>
                        </group>
                    </group>
                    <group string="Assuré (si différent du bénéficiaire)">
                        <field name="est_assure"/>
                        <field name="assure_nom" invisible="est_assure"/>
                        <field name="assure_prenom" invisible="est_assure"/>
                        <field name="assure_dn" invisible="est_assure"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_patient_list" model="ir.ui.view">
        <field name="name">cps.patient.list</field>
        <field name="model">cps.patient</field>
        <field name="arch" type="xml">
            <tree string="Patients">
                <field name="display_name"/>
                <field name="dn"/>
                <field name="date_naissance"/>
                <field name="tel"/>
                <field name="feuille_count"/>
            </tree>
        </field>
    </record>

    <record id="view_patient_search" model="ir.ui.view">
        <field name="name">cps.patient.search</field>
        <field name="model">cps.patient</field>
        <field name="arch" type="xml">
            <search>
                <field name="nom"/>
                <field name="prenom"/>
                <field name="dn"/>
            </search>
        </field>
    </record>

    <record id="action_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">cps.patient</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_patient_search"/>
    </record>
</odoo>
