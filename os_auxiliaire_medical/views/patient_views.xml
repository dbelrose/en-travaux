<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_patient_form" model="ir.ui.view">
        <field name="name">cps.patient.form</field>
        <field name="model">cps.patient</field>
        <field name="arch" type="xml">
            <form string="Patient">
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_feuilles" type="object" class="oe_stat_button"
                                icon="fa-file-medical">
                            <field name="feuille_count" widget="statinfo" string="Feuilles"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="display_name" readonly="1"/></h1>
                    </div>

                    <!--
                        Contact Odoo sous-jacent.
                        • Patient déjà dans vos contacts → le sélectionner ici.
                          Nom, prénom, date de naissance et coordonnées seront
                          repris directement depuis la fiche contact (sans doublon).
                        • Nouveau patient → laisser vide.
                          Un contact sera créé automatiquement à l'enregistrement.
                    -->
                    <group string="Lien contact Odoo">
                        <field name="partner_id"
                               domain="[('is_company', '=', False)]"
                               help="Sélectionnez un contact existant ou laissez vide pour en créer un nouveau."/>
                        <field name="company_id" groups="base.group_multi_company"/>
                    </group>

                    <group>
                        <group string="Identité CPS">
                            <!-- related → partner_id.lastname -->
                            <field name="nom"/>
                            <!-- related → partner_id.firstname -->
                            <field name="prenom"/>
                            <field name="dn"/>
                            <!-- related → partner_id.birthdate_date -->
                            <field name="date_naissance"/>
                        </group>
                        <group string="Coordonnées (partagées avec le contact Odoo)">
                            <!-- Champs hérités de res.partner via _inherits -->
                            <field name="phone"  string="Téléphone"/>
                            <field name="mobile"/>
                            <field name="email"/>
                            <field name="street" string="Adresse"/>
                        </group>
                    </group>

                    <group string="Assuré (si différent du bénéficiaire)">
                        <field name="est_assure"/>
                        <field name="assure_nom"    invisible="est_assure"/>
                        <field name="assure_prenom" invisible="est_assure"/>
                        <field name="assure_dn"     invisible="est_assure"/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_patient_list" model="ir.ui.view">
        <field name="name">cps.patient.list</field>
        <field name="model">cps.patient</field>
        <field name="arch" type="xml">
            <tree string="Patients">
                <field name="display_name"/>
                <field name="dn"/>
                <field name="date_naissance"/>
                <field name="phone" string="Téléphone"/>
                <field name="feuille_count"/>
            </tree>
        </field>
    </record>

    <record id="view_patient_search" model="ir.ui.view">
        <field name="name">cps.patient.search</field>
        <field name="model">cps.patient</field>
        <field name="arch" type="xml">
            <search>
                <!-- nom/prenom sont des related stockés → recherche directe possible -->
                <field name="nom"    string="Nom"/>
                <field name="prenom" string="Prénom"/>
                <field name="dn"/>
                <field name="phone"  string="Téléphone"/>
            </search>
        </field>
    </record>

    <record id="action_patient" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">cps.patient</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="view_patient_search"/>
    </record>
</odoo>
