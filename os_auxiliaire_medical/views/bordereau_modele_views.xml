<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Liste ─────────────────────────────────────────────────────────── -->
    <record id="view_bordereau_modele_list" model="ir.ui.view">
        <field name="name">cps.bordereau.modele.list</field>
        <field name="model">cps.bordereau.modele</field>
        <field name="arch" type="xml">
            <tree string="Modèles de bordereau">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="is_default"/>
                <field name="company_id" />
                <field name="afficher_dn"/>
                <field name="afficher_part_cps"/>
                <field name="afficher_part_patient"/>
                <field name="active" invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- ── Formulaire ────────────────────────────────────────────────────── -->
    <record id="view_bordereau_modele_form" model="ir.ui.view">
        <field name="name">cps.bordereau.modele.form</field>
        <field name="model">cps.bordereau.modele</field>
        <field name="arch" type="xml">
            <form string="Modèle de bordereau">
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group string="Général">
                            <field name="sequence"/>
                            <field name="is_default"/>
                            <field name="active"/>
                            <field name="company_id" />
                            <field name="couleur_principale"/>
                        </group>
                        <group string="Colonnes affichées">
                            <field name="afficher_dn"/>
                            <field name="afficher_date_naissance"/>
                            <field name="afficher_date_debut"/>
                            <field name="afficher_date_fin"/>
                            <field name="afficher_nb_actes"/>
                            <field name="afficher_part_cps"/>
                            <field name="afficher_part_patient"/>
                            <field name="afficher_total_ligne"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Textes">
                            <group string="En-tête">
                                <field name="entete_texte" nolabel="1"
                                       placeholder="Texte affiché en haut du bordereau…"
                                       style="min-height:80px;"/>
                            </group>
                            <group string="Pied de page">
                                <field name="pied_page_texte" nolabel="1"
                                       placeholder="Coordonnées, signature…"
                                       style="min-height:60px;"/>
                            </group>
                            <group string="Mention complémentaire">
                                <field name="mention_complementaire" nolabel="1"
                                       placeholder="Mention légale ou informative…"
                                       style="min-height:60px;"/>
                            </group>
                        </page>
                        <page string="Notes">
                            <field name="notes" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_bordereau_modele" model="ir.actions.act_window">
        <field name="name">Modèles de bordereau</field>
        <field name="res_model">cps.bordereau.modele</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>
