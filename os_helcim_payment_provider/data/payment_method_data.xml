<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <!--
        Méthode de paiement par carte bancaire pour Helcim.
        Helcim supporte les cartes Visa, Mastercard, Amex, Discover.
    -->
    <record id="payment_method_helcim_card" model="payment.method">
        <field name="name">Carte bancaire (Helcim)</field>
        <field name="code">card</field>
        <field name="sequence">10</field>
        <field name="active" eval="True"/>
        <field name="provider_ids" eval="[(4, ref('payment_provider_helcim'))]"/>
    </record>

</odoo>
