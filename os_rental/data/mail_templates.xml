<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">

        <record id="email_template_payment_link" model="mail.template">
            <field name="name">Lien de paiement - Réservation</field>
            <field name="model_id" ref="os_rental.model_booking_reservation"/>

            <!-- Destinataire : email du client de la réservation -->
            <field name="email_to">{{ object.partner_id.email or '' }}</field>

            <!-- Expéditeur : email de la société -->
            <field name="email_from">{{ (object.company_id.email or user.email or '') }}</field>

            <!-- Adresse de réponse -->
            <field name="reply_to">contact@belroseplace.site</field>

            <!-- Sujet -->
            <field name="subject">Lien de paiement - Réservation {{ object.name }}</field>

            <!-- Corps HTML (identique à votre template exporté) -->
            <field name="body_html"><![CDATA[
<div>
    <t t-set="booking" t-value="object"/>
    <p style="margin:0 0 16px 0;">
        Bonjour <strong><t t-out="booking.partner_id.name or ''">Client</t></strong>,
    </p>
    <p style="margin:0 0 16px 0;">Merci d'avoir réservé avec nous !</p>

    <h3 style="margin:0 0 8px 0;font-size:18px;font-weight:500;">Détails de votre réservation</h3>
    <ul style="list-style:none;padding-left:0;margin:0 0 16px 0;">
        <li><strong>Référence :</strong> <t t-out="booking.name or ''"/></li>
        <li><strong>Logement :</strong> <t t-out="(booking.product_id and booking.product_id.name) or ''"/></li>
        <li><strong>Arrivée :</strong> <t t-out="(booking.start_date and format_date(booking.start_date)) or ''"/></li>
        <li><strong>Départ :</strong> <t t-out="(booking.end_date and format_date(booking.end_date)) or ''"/></li>
        <li><strong>Nombre de nuits :</strong> <t t-out="booking.nights or ''"/></li>
        <li>
            <strong>Montant total :</strong>
            <t t-out="booking.total_amount or 0"/> XPF
        </li>
    </ul>

    <t t-if="booking.billetweb_payment_url">
        <p style="margin:24px 0;">
            <a t-att-href="booking.billetweb_payment_url"
               style="background:#017e84;color:#fff;padding:10px 16px;border-radius:4px;text-decoration:none;display:inline-block;">
                Procéder au paiement
            </a>
        </p>
    </t>

    <p style="margin:0 0 16px 0;">Pour toute question, n'hésitez pas à nous contacter.</p>

    <hr style="border:none;border-top:1px solid #eee;margin:16px 0;"/>
    <p style="font-size:12px;color:#666;margin:0;">
        <strong><t t-out="(booking.company_id and booking.company_id.name) or ''"/></strong><br/>
        <t t-out="(booking.company_id and booking.company_id.phone) or ''"/><br/>
        <t t-out="(booking.company_id and booking.company_id.email) or ''"/>
    </p>
</div>
            ]]></field>
        </record>

    </data>
</odoo>
