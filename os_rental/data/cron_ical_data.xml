<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_sync_ical_calendars" model="ir.cron">
            <field name="name">Synchro calendriers iCal externes</field>
            <field name="model_id" ref="os_rental.model_booking_ical_source"/>
