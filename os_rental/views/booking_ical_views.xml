<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Liste des sources iCal ──────────────────────────────────────── -->
    <record id="view_booking_ical_source_tree" model="ir.ui.view">
        <field name="name">booking.ical.source.tree</field>
        <field name="model">booking.ical.source</field>
        <field name="arch" type="xml">
            <tree decoration-muted="not active">
                <field name="product_id"/>
                <field name="name"/>
                <field name="ical_url" widget="url"/>
                <field name="booking_count" string="Réservations importées"/>
                <field name="last_sync"/>
                <field name="last_error"/>
                <field name="active" column_invisible="1"/>
            </tree>
        </field>
    </record>

    <!-- ── Formulaire source iCal ──────────────────────────────────────── -->
    <record id="view_booking_ical_source_form" model="ir.ui.view">
        <field name="name">booking.ical.source.form</field>
        <field name="model">booking.ical.source</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_sync_now" string="Synchroniser maintenant"
                            type="object" class="oe_highlight"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="%(action_booking_reservation)d" type="action"
                                class="oe_stat_button" icon="fa-calendar">
                            <field name="booking_count" widget="statinfo"
                                   string="Réservations"/>
                        </button>
                    </div>

                    <group>
                        <group string="Configuration">
                            <field name="product_id"/>
                            <field name="name" placeholder="Airbnb, Booking.com, VRBO…"/>
                            <field name="active" widget="boolean_toggle"/>
                        </group>
                        <group string="Statut">
                            <field name="last_sync" readonly="1"/>
                            <field name="last_error" readonly="1"
                                   invisible="not last_error"/>
                        </group>
                    </group>

                    <group string="Import — URL iCal de la plateforme vers Odoo">
                        <field name="ical_url" widget="url"
                               placeholder="https://www.airbnb.com/calendar/ical/..."
                               colspan="2"/>
                        <div class="alert alert-info" role="alert" colspan="2">
                            <strong>Où trouver cette URL ?</strong>
                            <ul style="margin:6px 0 0;padding-left:16px;">
                                <li>
                                    <strong>Airbnb</strong> : Calendrier → Disponibilité →
                                    Synchroniser les calendriers → Exporter le calendrier
                                </li>
                                <li>
                                    <strong>Booking.com</strong> : Extranet →
                                    Calendrier → Synchronisation iCal → Exporter
                                </li>
                            </ul>
                        </div>
                    </group>

                    <group string="Export — URL iCal d'Odoo vers la plateforme">
                        <field name="ical_export_url" readonly="1"
                               widget="url" colspan="2"
                               help="Copiez cette URL dans les paramètres iCal d'Airbnb et Booking.com."/>
                        <div class="alert alert-success" role="alert" colspan="2">
                            <strong>Comment l'utiliser ?</strong>
                            Copiez l'URL ci-dessus et collez-la dans :
                            <ul style="margin:6px 0 0;padding-left:16px;">
                                <li>
                                    <strong>Airbnb</strong> : Calendrier → Disponibilité →
                                    Synchroniser les calendriers → Importer un calendrier
                                </li>
                                <li>
                                    <strong>Booking.com</strong> : Extranet →
                                    Calendrier → Synchronisation iCal → Importer
                                </li>
                            </ul>
                        </div>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ── Action ──────────────────────────────────────────────────────── -->
    <record id="action_booking_ical_source" model="ir.actions.act_window">
        <field name="name">Calendriers externes (iCal)</field>
        <field name="res_model">booking.ical.source</field>
        <field name="view_mode">tree,form</field>
    </record>

    <!-- ── Menu ────────────────────────────────────────────────────────── -->
    <menuitem id="menu_booking_ical"
              name="Calendriers externes (iCal)"
              parent="menu_booking_root"
              action="action_booking_ical_source"
              sequence="90"/>

</odoo>
