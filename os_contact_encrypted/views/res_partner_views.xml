<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══════════════════════════════════════════════════════════════════
         Vue FORMULAIRE contact — héritage
         ═══════════════════════════════════════════════════════════════════ -->
    <record id="view_partner_form_crypto" model="ir.ui.view">
        <field name="name">res.partner.form.crypto</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">

            <!-- Champs techniques invisibles -->
            <xpath expr="//sheet" position="inside">
                <field name="has_encrypted_data" invisible="1"/>
            </xpath>

            <!-- ── Bandeau de déverrouillage ────────────────────────────── -->
            <xpath expr="//sheet/div[@name='button_box']" position="after">
                <div class="alert alert-warning d-flex align-items-center gap-2"
                     role="alert"
                     invisible="not has_encrypted_data">
                    <i class="fa fa-lock fa-lg text-warning flex-shrink-0"/>
                    <div class="flex-grow-1 small">
                        <strong>Données chiffrées.</strong>
                        Saisissez votre mot de passe pour les déchiffrer.
                    </div>
                    <field name="session_password"
                           widget="password"
                           password="True"
                           placeholder="Mot de passe Odoo…"
                           nolabel="1"
                           style="max-width:200px; min-width:140px"/>
                </div>
            </xpath>

            <!-- ── Nom complet ───────────────────────────────────────────── -->
            <!--
                On masque le champ natif 'name' (qui contient le hint "Dupo. J.")
                et on affiche name_display à la place :
                  - sans MDP → hint + 🔒 (si chiffré)
                  - avec MDP → nom complet déchiffré
                  - non-propriétaire → 🔒 Dupo. J.
            -->
            <xpath expr="//field[@name='name']" position="attributes">
                <attribute name="invisible">has_encrypted_data</attribute>
            </xpath>
            <xpath expr="//field[@name='name']" position="after">
                <field name="name_display"
                       string="Nom"
                       invisible="not has_encrypted_data"
                       readonly="has_encrypted_data and not session_password"
                       required="False"
                       placeholder="Nom complet"/>
            </xpath>

            <!-- ── Téléphone ─────────────────────────────────────────────── -->
            <xpath expr="//field[@name='phone']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='phone']" position="after">
                <field name="phone_display"
                       string="Téléphone"
                       readonly="has_encrypted_data and not session_password"
                       placeholder="Téléphone"/>
            </xpath>

            <!-- ── Mobile ────────────────────────────────────────────────── -->
            <xpath expr="//field[@name='mobile']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='mobile']" position="after">
                <field name="mobile_display"
                       string="Mobile"
                       readonly="has_encrypted_data and not session_password"
                       placeholder="Mobile"/>
            </xpath>

            <!-- ── Email ─────────────────────────────────────────────────── -->
            <xpath expr="//field[@name='email']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='email']" position="after">
                <field name="email_display"
                       string="Email"
                       readonly="has_encrypted_data and not session_password"
                       placeholder="Email"/>
            </xpath>

        </field>
    </record>

    <!-- ═══════════════════════════════════════════════════════════════════
         Vue LISTE contacts — héritage
         ═══════════════════════════════════════════════════════════════════ -->
    <record id="view_partner_tree_crypto" model="ir.ui.view">
        <field name="name">res.partner.tree.crypto</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_tree"/>
        <field name="arch" type="xml">

            <!-- Colonne Téléphone → phone_display -->
            <xpath expr="//field[@name='phone']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='phone']" position="after">
                <field name="phone_display"
                       string="Téléphone"
                       optional="show"
                       readonly="1"/>
            </xpath>

            <!-- Colonne Mobile (ajoutée, optionnelle masquée par défaut) -->
            <xpath expr="//field[@name='phone_display']" position="after">
                <field name="mobile_display"
                       string="Mobile"
                       optional="hide"
                       readonly="1"/>
            </xpath>

            <!-- Colonne Email → email_display -->
            <xpath expr="//field[@name='email']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <xpath expr="//field[@name='email']" position="after">
                <field name="email_display"
                       string="Email"
                       optional="show"
                       readonly="1"/>
            </xpath>

        </field>
    </record>

</odoo>
