<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="res_config_settings_view_form_crypto" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.crypto</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//form" position="inside">
                <app data-string="Chiffrement des contacts"
                 string="Chiffrement des contacts"
                 name="os_contact_encrypted"
                 groups="base.group_erp_manager">


                    <div class="app_settings_block"
                         data-string="Chiffrement contacts"
                         id="crypto_settings"
                         groups="os_contact_encrypted.group_crypto_admin">

                        <h2>🔐 Chiffrement des contacts</h2>

                        <!-- ── Recherche ZK ──────────────────────────────────── -->
                        <div class="row mt16 o_settings_container">
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <span class="o_form_label">Recherche ZK — préfixe minimum</span>
                                    <div class="text-muted">
                                        Nombre minimum de caractères d'un mot pour déclencher
                                        la recherche dans les noms chiffrés.
                                        Les initiales (1 caractère) sont toujours acceptées.<br/>
                                        <em>Recommandé : 4 (ex. "Dupo" trouve "Dupont").</em>
                                    </div>
                                    <div class="content-group mt8">
                                        <div class="row">
                                            <label class="col-lg-7 o_light_label"
                                                   for="crypto_min_search_prefix_len">
                                                Longueur minimale du préfixe
                                            </label>
                                            <field name="crypto_min_search_prefix_len"
                                                   class="col-lg-2"/>
                                            <span class="col-lg-3 text-muted align-self-center">
                                                caractères (2–8)
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- ── Aperçu du nom ──────────────────────────────── -->
                            <div class="col-12 col-lg-6 o_setting_box">
                                <div class="o_setting_left_pane"/>
                                <div class="o_setting_right_pane">
                                    <span class="o_form_label">Aperçu du nom chiffré</span>
                                    <div class="text-muted">
                                        Nombre de caractères du <strong>premier segment</strong>
                                        du nom visibles sans saisir le mot de passe.<br/>
                                        Les autres segments n'affichent que leur initiale.<br/>
                                        <em>1 = initiales (D. J.) · 4 = Dupo. J.</em><br/>
                                        <strong>Doit être ≤ au préfixe minimum de recherche.</strong>
                                    </div>
                                    <div class="content-group mt8">
                                        <div class="row">
                                            <label class="col-lg-7 o_light_label"
                                                   for="crypto_display_name_chars">
                                                Caractères affichés (1er segment)
                                            </label>
                                            <field name="crypto_display_name_chars"
                                                   class="col-lg-2"/>
                                            <span class="col-lg-3 text-muted align-self-center">
                                                caractères (1–10)
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div><!-- /row -->

                        <div class="row">
                            <div class="col-12">
                                <div class="alert alert-info" role="alert">
                                    <i class="fa fa-info-circle me-1"/>
                                    <strong>Note :</strong> Modifier ces paramètres n'affecte pas
                                    les tokens déjà indexés. Pour re-indexer les contacts existants,
                                    chaque utilisateur doit ré-enregistrer ses contacts chiffrés.
                                </div>
                            </div>
                        </div>

                    </div><!-- /app_settings_block -->
                </app>
            </xpath>
        </field>
    </record>

</odoo>
