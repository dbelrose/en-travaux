<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_emergency_export_wizard_form" model="ir.ui.view">
        <field name="name">os.emergency.export.wizard.form</field>
        <field name="model">os.emergency.export.wizard</field>
        <field name="arch" type="xml">
            <form string="Récupération d'urgence — Chiffrement contacts">
                <sheet>
                    <!-- Champs techniques au niveau racine -->
                    <field name="state" invisible="1"/>
                    <field name="mode"  invisible="1"/>

                    <!-- Sélecteur de mode -->
                    <group invisible="state != 'form'">
                        <field name="mode" widget="radio"/>
                    </group>

                    <!-- VOLET 1 : Configuration initiale -->
                    <group invisible="mode != 'setup' or state != 'form'">
                        <!-- Bandeaux pleine largeur via div colspan -->
                        <div colspan="2">
                            <div class="alert alert-info w-100" role="alert">
                                <h5>Configuration de la clé de récupération d'urgence</h5>
                                Cette opération génère une paire de clés RSA-4096 pour l'administrateur.<br/>
                                <ul class="mb-0 mt-2">
                                    <li>La <strong>clé publique</strong> est stockée dans Odoo et permet de créer
                                        des sauvegardes chiffrées des clés utilisateurs.</li>
                                    <li>La <strong>clé privée</strong> (fichier PEM) est à télécharger et à conserver
                                        <em>hors ligne</em> dans un coffre-fort ou gestionnaire de secrets sécurisé.</li>
                                </ul>
                            </div>
                            <div class="alert alert-danger w-100 mt-2" role="alert">
                                <strong>Avertissement :</strong> Si la clé privée admin est perdue,
                                aucune récupération d'urgence ne sera possible.
                                Conservez ce fichier dans au moins deux endroits sécurisés distincts.
                            </div>
                        </div>
                        <group string="Mot de passe de la clé privée admin">
                            <field name="admin_password"         widget="password" placeholder="Mot de passe fort pour protéger la clé privée"/>
                            <field name="admin_password_confirm" widget="password" placeholder="Confirmer"/>
                        </group>
                    </group>

                    <!-- VOLET 2 : Accès d'urgence -->
                    <group invisible="mode != 'recover' or state != 'form'">
                        <div colspan="2">
                            <div class="alert alert-danger w-100" role="alert">
                                <h5>Accès d'urgence aux données d'un utilisateur</h5>
                                Cet accès sera <strong>journalisé</strong> dans le profil de l'utilisateur concerné
                                (date, administrateur, heure). N'utilisez cette fonctionnalité qu'en cas de
                                nécessité absolue et avec le consentement de votre DPO si applicable.
                            </div>
                        </div>
                        <group string="Utilisateur à récupérer">
                            <field name="target_user_id"/>
                        </group>
                        <group string="Clé privée administrateur">
                            <field name="admin_private_key_input" widget="text"
                                   placeholder="Collez ici le contenu du fichier emergency_admin_private.pem"/>
                            <field name="admin_key_password" widget="password" placeholder="Mot de passe de la clé privée admin"/>
                        </group>
                        <group string="Nouveau mot de passe pour l'utilisateur récupéré">
                            <field name="new_user_password"         widget="password" placeholder="Nouveau mot de passe Odoo"/>
                            <field name="new_user_password_confirm" widget="password" placeholder="Confirmer"/>
                        </group>
                    </group>

                    <!-- ÉTAT : Succès setup -->
                    <group invisible="state != 'done' or mode != 'setup'">
                        <div colspan="2">
                            <div class="alert alert-success w-100" role="alert">
                                <h5>Clé de récupération configurée</h5>
                                <field name="setup_done_info" readonly="1" nolabel="1"/>
                            </div>
                            <div class="alert alert-warning w-100 mt-2" role="alert">
                                <strong>Téléchargez la clé privée maintenant.</strong>
                                Cette fenêtre est la seule occasion de la récupérer.
                                Elle ne sera plus jamais accessible depuis Odoo.
                            </div>
                        </div>
                        <group string="Clé privée admin (à conserver hors-ligne)">
                            <field name="admin_private_key_export"
                                   filename="admin_private_key_filename"
                                   widget="binary"
                                   string="Télécharger emergency_admin_private.pem"/>
                            <field name="admin_private_key_filename" invisible="1"/>
                        </group>
                    </group>

                    <!-- ÉTAT : Succès recover -->
                    <group invisible="state != 'done' or mode != 'recover'">
                        <div colspan="2">
                            <div class="alert alert-success w-100" role="alert">
                                <h5>Récupération réussie</h5>
                                <field name="recovery_info" readonly="1" nolabel="1"/>
                            </div>
                            <div class="alert alert-info w-100 mt-2" role="alert">
                                Cet accès a été enregistré dans le profil de l'utilisateur concerné.
                            </div>
                        </div>
                    </group>

                    <!-- ÉTAT : Erreur -->
                    <group invisible="state != 'error'">
                        <div colspan="2">
                            <div class="alert alert-danger w-100" role="alert">
                                <h5>Erreur</h5>
                                <field name="error_message" readonly="1" nolabel="1"/>
                            </div>
                        </div>
                    </group>

                </sheet>
                <footer>
                    <button name="action_setup_emergency" type="object"
                            string="Générer la clé de récupération" class="btn btn-primary"
                            invisible="mode != 'setup' or state != 'form'"/>
                    <button name="action_recover" type="object"
                            string="Récupérer l'accès" class="btn btn-danger"
                            invisible="mode != 'recover' or state != 'form'"/>
                    <button name="action_retry" type="object"
                            string="Réessayer" class="btn btn-secondary"
                            invisible="state != 'error'"/>
                    <button name="action_close" type="object"
                            string="Fermer" class="btn btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_emergency_export_wizard" model="ir.actions.act_window">
        <field name="name">Récupération d'urgence</field>
        <field name="res_model">os.emergency.export.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="groups_id" eval="[(4, ref('os_contact_encrypted.group_crypto_admin'))]"/>
    </record>

</odoo>
