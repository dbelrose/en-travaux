<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_init_keypair_wizard_form" model="ir.ui.view">
        <field name="name">os.init.keypair.wizard.form</field>
        <field name="model">os.init.keypair.wizard</field>
        <field name="arch" type="xml">
            <form string="Initialisation du chiffrement RSA">
                <sheet>
                    <!-- Champs techniques déclarés au niveau racine pour les expressions invisible -->
                    <field name="state"    invisible="1"/>
                    <field name="has_keys" invisible="1"/>

                    <!-- État : formulaire -->
                    <group invisible="state != 'form'">
                        <div class="alert alert-info" role="alert">
                            <h5 class="mb-1">Chiffrement RSA personnel</h5>
                            Vos données de contact seront chiffrées avec une clé RSA-2048
                            protégée par votre mot de passe Odoo. Personne d'autre — pas même
                            l'administrateur — ne pourra lire ces données sans votre mot de passe.
                        </div>
                        <div class="alert alert-warning" role="alert"
                             invisible="not has_keys">
                            Vous avez déjà des clés configurées. Régénérer les clés
                            rendra illisibles les données chiffrées existantes.
                            Cochez la case ci-dessous uniquement si nécessaire.
                        </div>
                        <group string="Authentification">
                            <field name="password"         widget="password" placeholder="Votre mot de passe de connexion Odoo"/>
                            <field name="password_confirm" widget="password" placeholder="Confirmer le mot de passe"/>
                        </group>
                        <group string="Options avancées" invisible="not has_keys">
                            <field name="force_regenerate"/>
                            <div class="alert alert-danger mt-1" role="alert"
                                 invisible="not warning_regen">
                                <field name="warning_regen" readonly="1" nolabel="1"/>
                            </div>
                        </group>
                    </group>

                    <!-- État : succès -->
                    <group invisible="state != 'done'">
                        <div class="alert alert-success" role="alert">
                            <h5>Clés générées avec succès !</h5>
                            Votre paire de clés RSA est prête. Vos données sont protégées
                            et lisibles <strong>uniquement par vous</strong>.
                        </div>
                    </group>

                    <!-- État : déjà initialisé -->
                    <group invisible="state != 'already'">
                        <div class="alert alert-warning" role="alert">
                            <h5>Clés déjà configurées</h5>
                            Vos clés de chiffrement sont déjà actives.
                            Cochez "Régénérer les clés" si nécessaire.
                            <strong>Attention : vos données existantes seront illisibles.</strong>
                        </div>
                    </group>

                    <!-- État : erreur -->
                    <group invisible="state != 'error'">
                        <div class="alert alert-danger" role="alert">
                            <h5>Erreur</h5>
                            <field name="error_message" readonly="1" nolabel="1"/>
                        </div>
                    </group>

                </sheet>
                <footer>
                    <button name="action_generate" type="object"
                            string="Générer les clés" class="btn btn-primary"
                            invisible="state not in ['form', 'already']"/>
                    <button name="action_retry" type="object"
                            string="Réessayer" class="btn btn-secondary"
                            invisible="state != 'error'"/>
                    <button name="action_close" type="object"
                            string="Fermer" class="btn btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_init_keypair_wizard" model="ir.actions.act_window">
        <field name="name">Initialiser le chiffrement</field>
        <field name="res_model">os.init.keypair.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="groups_id" eval="[(4, ref('os_contact_encrypted.group_crypto_user'))]"/>
    </record>

</odoo>
