<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="view_change_password_wizard_form" model="ir.ui.view">
        <field name="name">os.change.password.wizard.form</field>
        <field name="model">os.change.password.wizard</field>
        <field name="arch" type="xml">
            <form string="Changement du mot de passe (avec re-chiffrement)">
                <sheet>
                    <!-- Champ technique déclaré au niveau racine -->
                    <field name="state" invisible="1"/>

                    <!-- Formulaire -->
                    <group invisible="state != 'form'">
                        <div class="alert alert-warning" role="alert">
                            <h5>Changement sécurisé du mot de passe</h5>
                            Ce wizard change simultanément votre <strong>mot de passe Odoo</strong>
                            et re-chiffre votre <strong>clé RSA privée</strong> avec le nouveau mot de passe.
                            Vos données de contact chiffrées restent accessibles avec le nouveau mot de passe.
                            <br/><br/>
                            <strong>N'utilisez pas le changement de mot de passe natif d'Odoo</strong>
                            si vous avez des données chiffrées.
                        </div>
                        <group string="Authentification">
                            <field name="old_password" widget="password" placeholder="Mot de passe actuel"
                                   password="True"
                            />
                        </group>
                        <group string="Nouveau mot de passe">
                            <field name="new_password"         widget="password" password="True"
                                   placeholder="Nouveau mot de passe (8 caractères min.)"/>
                            <field name="new_password_confirm" widget="password" password="True"
                                   placeholder="Confirmer le nouveau mot de passe"/>
                        </group>
                    </group>

                    <!-- Succès -->
                    <group invisible="state != 'done'">
                        <div class="alert alert-success" role="alert">
                            <h5>Mot de passe mis à jour</h5>
                            Votre mot de passe Odoo et votre clé RSA de chiffrement ont été
                            mis à jour simultanément. Vos données de contact chiffrées restent
                            accessibles avec votre nouveau mot de passe.
                        </div>
                    </group>

                    <!-- Erreur -->
                    <group invisible="state != 'error'">
                        <div class="alert alert-danger" role="alert">
                            <h5>Erreur</h5>
                            <field name="error_message" readonly="1" nolabel="1"/>
                        </div>
                    </group>

                </sheet>
                <footer>
                    <button name="action_change" type="object"
                            string="Changer le mot de passe" class="btn btn-primary"
                            invisible="state != 'form'"/>
                    <button name="action_retry" type="object"
                            string="Réessayer" class="btn btn-secondary"
                            invisible="state != 'error'"/>
                    <button name="action_close" type="object"
                            string="Fermer" class="btn btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_change_password_wizard" model="ir.actions.act_window">
        <field name="name">Changer mon mot de passe</field>
        <field name="res_model">os.change.password.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="groups_id" eval="[(4, ref('os_contact_encrypted.group_crypto_user'))]"/>
    </record>

</odoo>
