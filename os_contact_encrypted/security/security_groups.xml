<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- Catégorie visible dans Paramètres → Utilisateurs & Sociétés → Groupes -->
        <record id="module_os_contact_encrypted" model="ir.module.category">
            <field name="name">Chiffrement Contacts</field>
            <field name="description">Gestion du chiffrement RSA des données sensibles des contacts</field>
            <field name="sequence">100</field>
            <!-- visible=True permet l'affichage dans la fiche utilisateur -->
        </record>

        <!-- Groupe utilisateur : affiché dans la fiche utilisateur -->
        <record id="group_crypto_user" model="res.groups">
            <field name="name">Utilisateur chiffrement</field>
            <field name="category_id" ref="module_os_contact_encrypted"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <!-- Groupe administrateur : affiché dans la fiche utilisateur -->
        <record id="group_crypto_admin" model="res.groups">
            <field name="name">Administrateur chiffrement</field>
            <field name="category_id" ref="module_os_contact_encrypted"/>
            <field name="implied_ids" eval="[(4, ref('group_crypto_user'))]"/>
            <field name="users" eval="[(4, ref('base.user_admin'))]"/>
        </record>

    </data>
</odoo>
